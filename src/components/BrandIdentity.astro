---
interface Props {
  href: string;
  manual?: boolean;
  imageSrc: string;
}

const { href, manual = false, imageSrc } = Astro.props;
---

<a class:list={["brand", { "manual-site-brand": manual }]} href={href}>
  <span class:list={["brand-avatar", { "manual-brand-avatar": manual }]}>
    <img src={imageSrc} alt="schemaX" width="56" height="56" />
  </span>
  <span class:list={["brand-copy", { "manual-brand-copy": manual }]}>
    <span class:list={["brand-mark", { "manual-brand-mark": manual }]}>schemaX</span>
    <span class:list={["brand-subtitle", { "manual-brand-subtitle": manual }]}>绝密计划 · classified</span>
  </span>
</a>
