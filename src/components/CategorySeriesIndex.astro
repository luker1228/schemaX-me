---
import BlogDirectory from "./BlogDirectory.astro";
import { formatDate, getCategoryDescription, getCategoryGroups, getCategoryLabel, type Category, type NormalizedPost } from "../lib/content";

interface Props {
  category: Category;
  allPosts: NormalizedPost[];
  posts?: NormalizedPost[];
  currentGroup?: string | null;
  basePath?: string;
}

const { category, allPosts, posts = allPosts, currentGroup = null, basePath = import.meta.env.BASE_URL.replace(/\/?$/, "/") } = Astro.props;
const topicGroups = getCategoryGroups(allPosts, category, basePath);
const currentGroupLabel = currentGroup ? topicGroups.find((group) => group.key === currentGroup)?.label ?? currentGroup : "最近文章";
---

<section class="shell-wide category-series-shell">
  <div class="section-head">
    <h2>{getCategoryLabel(category)}</h2>
    <p>{getCategoryDescription(category)}</p>
  </div>

  <div class="blog-layout">
    <BlogDirectory activeSection="categories" activeCategory={category} />

    <div class="blog-content">
      <div class="blog-list-shell" id="recent-articles">
        <div class="home-section-head">
          <h2>{currentGroupLabel}</h2>
          <p>{currentGroup ? "按时间倒序展示这一组文章。" : "按时间倒序展示当前分类下的全部文章。"}</p>
        </div>

        <div class="blog-list">
          {posts.map((post) => (
            <a class="blog-list-item" href={`${basePath}blogs/posts/${post.slug}/`}>
              <span class="blog-list-date">{formatDate(post.pubDate)}</span>
              <div class="blog-list-body">
                <span class="blog-list-tag">{getCategoryLabel(post.category)}</span>
                <strong>{post.title}</strong>
                <p>{post.description || "从一个长期问题切出一个足够扎实的剖面。"}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
