---
import lukeIp from "../../assets/luke_ip.jpg";

const navItems = [
  { href: "/", label: "Works" },
  { href: "/archive/", label: "Blog" },
  { href: "/modelcraft/", label: "ModelCraft" },
  { href: "/#about", label: "About" },
  { href: "https://github.com/luker1228", label: "GitHub", external: true }
];
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="shell shell-wide">
    <a class="brand" href={baseUrl}>
      <span class="brand-avatar">
        <img src={lukeIp.src} alt="Luke 的个人 IP 形象" width={lukeIp.width} height={lukeIp.height} />
      </span>
      <span class="brand-copy">
        <span class="brand-mark">Luke Lab</span>
        <span class="brand-subtitle">Build. Write. Teach. Ship.</span>
      </span>
    </a>
    <nav class="nav">
      {navItems.map((item) => (
        <a
          href={item.external ? item.href : `${baseUrl}${item.href.replace(/^\//, "")}`}
          aria-current={!item.external && item.href !== "/#about" && currentPath === `${baseUrl}${item.href.replace(/^\//, "")}` ? "page" : undefined}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noreferrer" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
