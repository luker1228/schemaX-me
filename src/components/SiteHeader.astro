---
import lukeIp from "../../assets/luke2.webp";

const navItems = [
  { href: "/", label: "首页" },
  { href: "/#stack", label: "技术栈" },
  { href: "/blogs/", label: "博客" },
  { href: "/howto/", label: "前端手册" },
  { href: "/#works", label: "内容入口" },
  { href: "https://github.com/luker1228", label: "GitHub", external: true }
];
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="shell shell-wide">
    <a class="brand" href={baseUrl}>
      <span class="brand-avatar">
        <img src={lukeIp.src} alt="Luke 的个人 IP 形象" width={lukeIp.width} height={lukeIp.height} />
      </span>
      <span class="brand-copy">
        <span class="brand-mark">schemaX</span>
        <span class="brand-subtitle">绝密计划 · CLASSIFIED</span>
      </span>
    </a>
    <nav class="nav">
      {navItems.map((item) => (
        <a
          href={item.external ? item.href : `${baseUrl}${item.href.replace(/^\//, "")}`}
          aria-current={!item.external && item.href !== "/#about" && currentPath === `${baseUrl}${item.href.replace(/^\//, "")}` ? "page" : undefined}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noreferrer" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
