---
const navItems = [
  { href: "/ai/", label: "AI" },
  { href: "/cs/", label: "CS" },
  { href: "/english/", label: "English" },
  { href: "/life/", label: "Life" },
  { href: "/archive/", label: "Archive" }
];
---

<header class="site-header">
  <div class="shell shell-wide">
    <a class="brand" href={import.meta.env.BASE_URL}>Luke's AI Hub</a>
    <nav class="nav">
      {navItems.map((item) => (
        <a href={`${import.meta.env.BASE_URL}${item.href.replace(/^\//, "")}`}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
