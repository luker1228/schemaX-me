---
import { formatDate, getCategoryLabel, type NormalizedPost } from "../lib/content";

interface Props {
  post: NormalizedPost;
}

const { post } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<article class="post-card">
  <p class="category-kicker">{getCategoryLabel(post.category)}</p>
  <h3>
    <a href={`${baseUrl}posts/${post.slug}/`}>{post.title}</a>
  </h3>
  <p class="meta">{formatDate(post.pubDate)}</p>
  {post.description && <p>{post.description}</p>}
</article>
