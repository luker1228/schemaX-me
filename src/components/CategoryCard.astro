---
import { getCategoryDescription, getCategoryLabel, type Category } from "../lib/content";

interface Props {
  category: Category;
  count: number;
}

const { category, count } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<a class="category-card" href={`${baseUrl}${category}/`}>
  <div>
    <p class="category-kicker">{getCategoryLabel(category)}</p>
    <h3>{getCategoryLabel(category)}</h3>
    <p>{getCategoryDescription(category)}</p>
  </div>
  <p class="meta">{count} 篇文章</p>
</a>
