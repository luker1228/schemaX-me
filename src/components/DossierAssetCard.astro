---
// 课程/手册入口卡 —— 最简 RetroUI 基线卡。
// 结构沿用 shadcn/ui Card 的语义切分:head(title + desc)/ body / foot。
// 视觉遵循 DESIGN.md「Open Field Manual」:暖纸面、深墨水边框、方形、仅 hover 出硬阴影。
type Tone = "yellow" | "green" | "red" | "purple";

interface Props {
  code: string;
  status: string;
  title: string;
  copy: string;
  meta: string;
  href?: string;
  tone?: Tone;
  className?: string;
}

const {
  code,
  status,
  title,
  copy,
  meta,
  href,
  tone = "yellow",
  className = ""
} = Astro.props;

// href="#" 在首页约定为「预告/未上线」:渲染成不可点的静态卡。
const isPlaceholder = !href || href === "#";
const Tag = isPlaceholder ? "div" : "a";
const cardClass = [
  "fm-card",
  `fm-card-${tone}`,
  isPlaceholder ? "fm-card-placeholder" : "",
  className
]
  .filter(Boolean)
  .join(" ");
---

<Tag class={cardClass} href={isPlaceholder ? undefined : href}>
  <header class="fm-card-head">
    <span class="fm-card-code">{code}</span>
    <span class="fm-card-status" data-tone={tone}>● {status}</span>
  </header>

  <div class="fm-card-body">
    <h3 class="fm-card-title">{title}</h3>
    <p class="fm-card-desc">{copy}</p>
  </div>

  <footer class="fm-card-foot">
    <span class="fm-card-meta">{meta} →</span>
  </footer>
</Tag>

<style>
  /* 卡片本体:暖纸面 + 深墨水 1px 边框 + 方形角,默认无阴影。
     只有 hover 才升起一层深色硬阴影,符合 DESIGN.md 的「No-Blur」「Action shadow」规范。
     颜色全部走 token:浅色 dossier 皮肤下 --border/--text/--surface 被 body:has(.dossier) 重定义,
     暗色主题下回退到 tokens.css 的根值,组件不需要知道当前在哪套皮肤。 */
  .fm-card {
  display: grid;
  grid-template-rows: auto 1fr auto;
  gap: 0.85rem;
  padding: 1.25rem 1.35rem;
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text);
  text-decoration: none;
  transition: transform 160ms cubic-bezier(0.2, 0.8, 0.2, 1),
              box-shadow 160ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .fm-card:hover {
  transform: translate(-3px, -3px);
  box-shadow: 6px 6px 0 var(--border);
  }

  /* —— Header:代号 + 状态,monospace 元数据 —— */
  .fm-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  font-family: var(--font-mono, "SFMono-Regular", "JetBrains Mono", Consolas, monospace);
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  }

  .fm-card-code {
  color: var(--text-soft);
  text-transform: uppercase;
  }

  .fm-card-status {
  font-weight: 700;
  text-transform: uppercase;
  }

  /* 状态点按 tone 着色，用 accent/signal token，在纸面上清晰可读。 */
  .fm-card-status[data-tone="yellow"] { color: var(--accent); }
  .fm-card-status[data-tone="green"]  { color: #1a5c38; }
  .fm-card-status[data-tone="red"]    { color: var(--red); }
  .fm-card-status[data-tone="purple"] { color: #6b3fb0; }

  /* —— Body:标题 + 描述 —— */
  .fm-card-title {
  margin: 0;
  font-family: var(--font-display, "Arial Black", Impact, sans-serif);
  font-weight: 900;
  font-size: clamp(1.15rem, 1.4vw, 1.4rem);
  line-height: 1.1;
  letter-spacing: -0.005em;
  }

  .fm-card-desc {
  margin: 0.4rem 0 0;
  color: var(--text-soft);
  font-size: 0.92rem;
  line-height: 1.65;
  }

  /* —— Footer:动作 CTA,单行轻提示,不做装饰边框 —— */
  .fm-card-foot {
  margin-top: 0.25rem;
  }

  .fm-card-meta {
  font-family: var(--font-mono, "SFMono-Regular", "JetBrains Mono", Consolas, monospace);
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  color: var(--text-soft);
  }

  .fm-card:not(.fm-card-placeholder):hover .fm-card-meta {
  color: var(--text);
  }

  /* —— 预告卡(href="#"):不可点,弱化 —— */
  .fm-card-placeholder {
  cursor: default;
  opacity: 0.72;
  }

  .fm-card-placeholder:hover {
  transform: none;
  box-shadow: none;
  }

  @media (prefers-reduced-motion: reduce) {
  .fm-card,
  .fm-card:hover { transition: none; transform: none; }
  }
</style>
