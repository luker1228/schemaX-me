---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "schemaX 绝密计划",
  description = "schemaX 绝密计划 · 人类大模型 Luke 的技术档案:技术写作、前端教学与可运行 Demo 的统一入口。"
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://luker1228.github.io").toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
