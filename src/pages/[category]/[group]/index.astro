---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CategorySeriesIndex from "../../../components/CategorySeriesIndex.astro";
import {
  CATEGORIES,
  getAllPosts,
  getCategoryGroups,
  getCategoryDescription,
  getPostGroup,
  type Category
} from "../../../lib/content";

export async function getStaticPaths() {
  const posts = await getAllPosts();

  return CATEGORIES.flatMap((category) => {
    const categoryPosts = posts.filter((post) => post.category === category);
    return getCategoryGroups(categoryPosts, category).map((group) => ({
      params: { category, group: group.key }
    }));
  });
}

const { category, group } = Astro.params as { category: Category; group: string };
const allPosts = (await getAllPosts()).filter((post) => post.category === category);
const posts = allPosts.filter((post) => getPostGroup(post) === group);
const groupLabel = getCategoryGroups(allPosts, category).find((item) => item.key === group)?.label ?? group;
---

<BaseLayout title={`${groupLabel} | Luke's AI Hub`} description={getCategoryDescription(category)}>
  <CategorySeriesIndex category={category} allPosts={allPosts} posts={posts} currentGroup={group} />
</BaseLayout>
