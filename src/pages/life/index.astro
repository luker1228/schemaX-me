---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategorySeriesIndex from "../../components/CategorySeriesIndex.astro";
import { getCategoryDescription, getPostsByCategory } from "../../lib/content";

const category = "life";
const posts = await getPostsByCategory(category);
---

<BaseLayout title="Life | Luke's AI Hub" description={getCategoryDescription(category)}>
  <CategorySeriesIndex category={category} allPosts={posts} />
</BaseLayout>
