---
import BaseLayout from "../layouts/BaseLayout.astro";
import graphqlSvg from "../../assets/icons/graphql.svg";
import dockerSvg from "../../assets/icons/docker.svg";
import goSvg from "../../assets/icons/go.svg";
import javaSvg from "../../assets/icons/java.svg";
import k8sSvg from "../../assets/icons/k8s-official.svg";
import mysqlSvg from "../../assets/icons/mysql-official.svg";
import nodejsSvg from "../../assets/icons/nodejs.svg";
import pythonSvg from "../../assets/icons/python.svg";
import { getAllPosts } from "../lib/content";

const posts = await getAllPosts();
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;
const graphqlSvgSrc = typeof graphqlSvg === "string" ? graphqlSvg : graphqlSvg.src;
const dockerSvgSrc = typeof dockerSvg === "string" ? dockerSvg : dockerSvg.src;
const goSvgSrc = typeof goSvg === "string" ? goSvg : goSvg.src;
const nodejsSvgSrc = typeof nodejsSvg === "string" ? nodejsSvg : nodejsSvg.src;
const pythonSvgSrc = typeof pythonSvg === "string" ? pythonSvg : pythonSvg.src;
const k8sSvgSrc = typeof k8sSvg === "string" ? k8sSvg : k8sSvg.src;
const mysqlSvgSrc = typeof mysqlSvg === "string" ? mysqlSvg : mysqlSvg.src;

const featuredWorks = [
  {
    index: "01",
    label: "Tech Writing",
    title: "技术博客",
    copy: "记录我在后端工程、AI Agent、数据模型、低代码、部署与工程化方面的实践思考。",
    href: withBase("/blogs/"),
    tone: "yellow",
    meta: `${posts.length} 篇已发布内容`
  },
  {
    index: "02",
    label: "Frontend Guide",
    title: "前端教学",
    copy: "写给后端同学、设计同学和零基础学习者的前端速通手册，后续会从其它仓库接入。",
    href: "#frontend-guide",
    tone: "cyan",
    meta: "预留入口"
  },
  {
    index: "03",
    label: "Series",
    title: "系列文章",
    copy: "进入长期系列入口，统一查看 ModelCraft 与后续系列。",
    href: withBase("/blogs/series/"),
    tone: "purple",
    meta: "Series Index"
  }
];

const guideSteps = [
  "从 Markdown 理解 HTML",
  "从盒子模型理解 CSS",
  "从交互理解 JavaScript",
  "从组件理解 React",
  "从提示词理解 AI 写前端"
];

const techStack = [
  {
    label: "Python",
    copy: "Automation, agents, scripts",
    src: pythonSvgSrc,
    accent: "yellow",
    featured: true
  },
  {
    label: "GraphQL",
    copy: "Schema-first APIs",
    src: graphqlSvgSrc,
    accent: "cyan"
  },
  {
    label: "Docker",
    copy: "Portable runtime",
    src: dockerSvgSrc,
    accent: "purple"
  },
  {
    label: "Go",
    copy: "Services & tools",
    src: goSvgSrc,
    accent: "green"
  },
  {
    label: "Java",
    copy: "Enterprise services",
    src: typeof javaSvg === "string" ? javaSvg : javaSvg.src,
    accent: "red"
  },
  {
    label: "Kubernetes",
    copy: "Cluster orchestration",
    src: k8sSvgSrc,
    accent: "blue"
  },
  {
    label: "MySQL",
    copy: "Relational storage",
    src: mysqlSvgSrc,
    accent: "orange"
  },
  {
    label: "TypeScript",
    copy: "Frontend systems",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg",
    accent: "yellow"
  },
  {
    label: "Astro",
    copy: "Static publishing",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg",
    accent: "cyan"
  }
];

const heroOrbit = [
  {
    label: "React",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg",
    className: "orbit-react"
  },
  {
    label: "GraphQL",
    src: graphqlSvgSrc,
    className: "orbit-graphql"
  },
  {
    label: "Node.js",
    src: nodejsSvgSrc,
    className: "orbit-node"
  },
  {
    label: "Python",
    src: pythonSvgSrc,
    className: "orbit-python"
  },
  {
    label: "Docker",
    src: dockerSvgSrc,
    className: "orbit-docker"
  },
  {
    label: "Java",
    src: typeof javaSvg === "string" ? javaSvg : javaSvg.src,
    className: "orbit-java"
  },
  {
    label: "Go",
    src: goSvgSrc,
    className: "orbit-go"
  }
];
---

<BaseLayout title="Luke Lab" description="Luke 的个人技术实验室，统一承接技术写作、前端教学与可运行 Demo。">
  <section class="shell-wide home-hero lab-hero">
    <div class="home-panel lab-panel lab-panel-hero">
      <div class="lab-hero-orbit" aria-hidden="true">
        {heroOrbit.map((item) => (
          <span class={`orbit-icon ${item.className}`}>
            <img src={item.src} alt="" width="64" height="64" loading="lazy" decoding="async" />
          </span>
        ))}
      </div>

      <div class="lab-hero-copy">
        <span class="eyebrow">Luke Lab / Personal Tech Lab</span>
        <h1 class="home-hero-title">学无止境<br />学以致用</h1>
        <p class="hero-copy hero-copy-en">
          Luke's lab for engineering notes, frontend learning, and runnable product demos.
        </p>
        <p class="hero-copy">
          这里是 Luke 的个人技术实验室，收集我的技术写作、前端教学和 Demo 项目。重点不在概念堆叠，而在把复杂问题讲清楚，把想法做成能跑的产品。
        </p>

        <div class="hero-actions">
          <a class="site-button site-button-primary" href="#works">查看作品</a>
          <a class="site-button site-button-secondary" href="#stack">技术栈</a>
        </div>

        <div class="hero-stats" aria-label="Luke Lab overview">
          <div class="stat-box stat-box-yellow">
            <span class="stat-label">Writing</span>
            <strong>{posts.length}</strong>
          </div>
          <div class="stat-box stat-box-cyan">
            <span class="stat-label">Core Stack</span>
            <strong>{techStack.length}</strong>
          </div>
          <div class="stat-box stat-box-purple">
            <span class="stat-label">Sections</span>
            <strong>3</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="shell-wide home-section stack-section" id="stack">
    <div class="home-section-head stack-section-head">
      <h2>技术栈</h2>
      <p>我所熟悉的技术栈</p>
    </div>

    <div class="lab-stack-panel">
      <div class="stack-marquee" aria-label="技术栈展示">
        <ul class="stack-marquee-list">
          {techStack.map((item) => (
            <li class={`stack-marquee-item stack-marquee-item-${item.accent}`}>
              <img src={item.src} alt="" width="28" height="28" loading={item.featured ? "eager" : "lazy"} decoding="async" />
              <span>{item.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="shell-wide home-section" id="works">
    <div class="home-section-head">
      <h2>Featured Works</h2>
      <p>Luke Lab 统一品牌，具体内容会分布在主站和不同子项目里。</p>
    </div>

    <div class="works-grid lab-works-grid">
      {featuredWorks.map((item) => (
        <a class={`theme-card work-card work-card-${item.tone}`} href={item.href}>
          <span class="panel-kicker">{item.index} / {item.label}</span>
          <strong>{item.title}</strong>
          <p>{item.copy}</p>
          <span class="note-date">{item.meta}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="shell-wide home-section" id="frontend-guide">
    <div class="home-columns lab-columns">
      <article class="manifesto-card lab-guide-card">
        <span class="panel-kicker">Frontend Guide For Backend Developers</span>
        <h3>前端教学路线</h3>
        <p>这一部分会独立成仓，但主站会保留教学路线与索引，方便快速理解内容结构。</p>
        <div class="guide-steps">
          {guideSteps.map((step, index) => (
            <div class="guide-step">
              <span class="guide-step-index">{String(index + 1).padStart(2, "0")}</span>
              <strong>{step}</strong>
            </div>
          ))}
        </div>
      </article>

      <aside class="feature-card work-card-cyan lab-placeholder-card">
        <span class="featured-tag">Reserved</span>
        <h3>前端教学仓库稍后接入</h3>
        <p>当前首页先保留清晰入口，不在这个仓库里硬塞教学内容。</p>
      </aside>
    </div>
  </section>

  <section class="shell-wide home-section" id="product-demo">
    <div class="home-columns lab-columns">
      <article class="spotlight-card work-card-purple">
        <span class="panel-kicker">Product Demo</span>
        <h3>可运行的 Demo 会放在这里</h3>
        <p>主站会展示 Demo 截图、项目解决的问题、技术栈，以及在线体验和 GitHub 入口。现在先把结构定住，等外部仓库接入。</p>
        <div class="demo-stack">
          <span class="stack-chip">Product thinking</span>
          <span class="stack-chip">Engineering delivery</span>
          <span class="stack-chip">Runnable prototype</span>
        </div>
      </article>

      <aside class="lab-screenshot-card">
        <span class="panel-kicker">Demo board</span>
        <div class="terminal-window">
          <div class="terminal-bar">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="terminal-body">
            <p>$ luke-lab demo status</p>
            <p>&gt; pending external repos</p>
            <p>&gt; reserve area for live product screenshots</p>
            <p>&gt; links will point to real runnable demos</p>
          </div>
        </div>
      </aside>
    </div>
  </section>

</BaseLayout>
