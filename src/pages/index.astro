---
import BaseLayout from "../layouts/BaseLayout.astro";
import lukeIp from "../../assets/luke_ip.jpg";
import lukeIpPortrait from "../../assets/luke_ip_34.png";
import { formatDate, getAllPosts, getPostsBySeries } from "../lib/content";

const posts = await getAllPosts();
const latestWriting = posts.slice(0, 4);
const modelcraftPosts = await getPostsBySeries("ModelCraft");
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;

const featuredWorks = [
  {
    index: "01",
    label: "Tech Writing",
    title: "技术博客",
    copy: "记录我在后端工程、AI Agent、数据模型、低代码、部署与工程化方面的实践思考。",
    href: withBase("/archive/"),
    tone: "yellow",
    meta: `${posts.length} 篇已发布内容`
  },
  {
    index: "02",
    label: "Frontend Guide",
    title: "前端教学",
    copy: "写给后端同学、设计同学和零基础学习者的前端速通手册，后续会从其它仓库接入。",
    href: "#frontend-guide",
    tone: "cyan",
    meta: "预留入口"
  },
  {
    index: "03",
    label: "Product Demo",
    title: "Demo 项目",
    copy: "展示我独立完成的实验性项目和产品 Demo，用真实可运行的系统验证想法。",
    href: "#product-demo",
    tone: "purple",
    meta: "预留入口"
  }
];

const guideSteps = [
  "从 Markdown 理解 HTML",
  "从盒子模型理解 CSS",
  "从交互理解 JavaScript",
  "从组件理解 React",
  "从提示词理解 AI 写前端"
];
---

<BaseLayout title="Luke Lab" description="Luke 的个人技术实验室，统一承接技术写作、前端教学与可运行 Demo。">
  <section class="shell-wide home-hero lab-hero">
    <div class="home-hero-grid lab-hero-grid">
      <div class="home-panel home-hero-copy lab-panel">
        <span class="eyebrow">Luke Lab / Personal Tech Lab</span>
        <h1 class="home-hero-title">Build. Write. Teach. Ship.</h1>
        <p class="hero-copy hero-copy-en">
          Luke's personal lab for engineering notes, frontend learning, and runnable product demos.
        </p>
        <p class="hero-copy">
          这里是 Luke 的个人技术实验室，收集我的技术写作、前端教学和 Demo 项目。它们来自不同方向，但共同指向一件事：把复杂问题讲清楚，把想法做成可以体验的产品。
        </p>

        <div class="hero-actions">
          <a class="site-button site-button-primary" href="#works">查看作品</a>
          <a class="site-button site-button-secondary" href="#product-demo">进入 Demo</a>
        </div>

        <div class="hero-stats" aria-label="Luke Lab overview">
          <div class="stat-box stat-box-yellow">
            <span class="stat-label">Writing</span>
            <strong>{posts.length}</strong>
          </div>
          <div class="stat-box stat-box-cyan">
            <span class="stat-label">Teaching</span>
            <strong>Planned</strong>
          </div>
          <div class="stat-box stat-box-purple">
            <span class="stat-label">Demo</span>
            <strong>Planned</strong>
          </div>
        </div>
      </div>

      <aside class="home-portrait lab-portrait">
        <img src={lukeIp.src} alt="Luke 的个人 IP 形象" width={lukeIp.width} height={lukeIp.height} loading="eager" />
        <div class="portrait-caption">
          <span class="panel-kicker">Luke</span>
          <strong>把复杂问题讲清楚，把想法做成产品。</strong>
        </div>
      </aside>
    </div>
  </section>

  <section class="shell-wide home-section" id="works">
    <div class="home-section-head">
      <h2>Featured Works</h2>
      <p>Luke Lab 统一品牌，具体内容会分布在主站和不同子项目里。</p>
    </div>

    <div class="works-grid lab-works-grid">
      {featuredWorks.map((item) => (
        <a class={`theme-card work-card work-card-${item.tone}`} href={item.href}>
          <span class="panel-kicker">{item.index} / {item.label}</span>
          <strong>{item.title}</strong>
          <p>{item.copy}</p>
          <span class="note-date">{item.meta}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="shell-wide home-section" id="frontend-guide">
    <div class="home-columns lab-columns">
      <article class="manifesto-card lab-guide-card">
        <span class="panel-kicker">Frontend Guide For Backend Developers</span>
        <h3>前端教学路线</h3>
        <p>这一部分会独立成仓，但主站会保留教学路线与索引，方便快速理解内容结构。</p>
        <div class="guide-steps">
          {guideSteps.map((step, index) => (
            <div class="guide-step">
              <span class="guide-step-index">{String(index + 1).padStart(2, "0")}</span>
              <strong>{step}</strong>
            </div>
          ))}
        </div>
      </article>

      <aside class="feature-card work-card-cyan lab-placeholder-card">
        <span class="featured-tag">Reserved</span>
        <h3>前端教学仓库稍后接入</h3>
        <p>当前首页先保留清晰入口，不在这个仓库里硬塞教学内容。</p>
      </aside>
    </div>
  </section>

  <section class="shell-wide home-section" id="product-demo">
    <div class="home-columns lab-columns">
      <article class="spotlight-card work-card-purple">
        <span class="panel-kicker">Product Demo</span>
        <h3>可运行的 Demo 会放在这里</h3>
        <p>主站会展示 Demo 截图、项目解决的问题、技术栈，以及在线体验和 GitHub 入口。现在先把结构定住，等外部仓库接入。</p>
        <div class="demo-stack">
          <span class="stack-chip">Product thinking</span>
          <span class="stack-chip">Engineering delivery</span>
          <span class="stack-chip">Runnable prototype</span>
        </div>
      </article>

      <aside class="lab-screenshot-card">
        <span class="panel-kicker">Demo board</span>
        <div class="terminal-window">
          <div class="terminal-bar">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="terminal-body">
            <p>$ luke-lab demo status</p>
            <p>&gt; pending external repos</p>
            <p>&gt; reserve area for live product screenshots</p>
            <p>&gt; links will point to real runnable demos</p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="shell-wide home-section" id="blog">
    <div class="home-section-head">
      <h2>Blog</h2>
      <p>技术博客是 Luke Lab 当前最完整的内容部分。下面这组卡片放最近更新，完整内容继续走 Blog 归档。</p>
    </div>

    <div class="post-grid">
      {latestWriting.map((post) => (
        <a class="post-card" href={withBase(`/posts/${post.slug}/`)}>
          <p class="category-kicker">{post.category}</p>
          <h3>{post.title}</h3>
          <p class="meta">{formatDate(post.pubDate)}</p>
          <p>{post.description || "从一个长期问题切出一个足够扎实的剖面。"}</p>
        </a>
      ))}
    </div>

    <div class="hero-actions section-actions">
      <a class="site-button site-button-primary" href={withBase("/archive/")}>进入 Blog</a>
      <a class="site-button site-button-secondary" href={withBase("/modelcraft/")}>查看 ModelCraft</a>
    </div>
  </section>

  <section class="shell-wide home-section" id="about">
    <div class="about-showcase">
      <div class="about-visual">
        <div class="about-visual-shadow" aria-hidden="true"></div>
        <div class="about-visual-frame">
          <img src={lukeIpPortrait.src} alt="Luke 的个人 IP 形象" width={lukeIpPortrait.width} height={lukeIpPortrait.height} loading="lazy" />
        </div>
      </div>

      <div class="about-copy" id="contact">
        <span class="featured-tag">About</span>
        <h2>About Luke</h2>
        <p>
          我是 Luke，一个关注 AI Agent、后端工程、前端表达和产品交付的开发者。我喜欢把工程经验整理成文章，也喜欢把复杂知识讲成可学习的路径。
        </p>
        <p>
          Luke Lab 把技术写作、前端教学和 Demo 项目放进同一个作品体系里。它们不要求主题完全一致，但都会指向同一件事：把复杂问题讲清楚，把想法做成可以体验的产品。
        </p>
        <p class="about-contact-copy">
          如果你想先看代码，从 GitHub 进入最快；如果你想看文章分发，也可以走掘金和博客园。
        </p>

        <div class="contact-actions">
          <a class="site-button site-button-primary" href="https://github.com/luker1228" target="_blank" rel="noreferrer">GitHub</a>
          <a class="site-button site-button-secondary" href="https://juejin.cn/user/2929553730971224/posts" target="_blank" rel="noreferrer">掘金</a>
          <a class="site-button site-button-secondary" href="https://www.cnblogs.com/patientcat" target="_blank" rel="noreferrer">博客园</a>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
