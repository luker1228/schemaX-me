---
import BaseLayout from "../layouts/BaseLayout.astro";
import DossierAssetCard from "../components/DossierAssetCard.astro";
import graphqlSvg from "../../assets/icons/graphql.svg";
import dockerSvg from "../../assets/icons/docker.svg";
import goSvg from "../../assets/icons/go.svg";
import javaSvg from "../../assets/icons/java.svg";
import k8sSvg from "../../assets/icons/k8s-official.svg";
import mysqlSvg from "../../assets/icons/mysql-official.svg";
import pythonSvg from "../../assets/icons/python.svg";
import motorcyclePortrait from "../../assets/ip/摩托11.png";
import sideProfilePortrait from "../../assets/ip/尖头发侧面.png";
import { getAllPosts, formatDate } from "../lib/content";

const posts = await getAllPosts();
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;

// —— DOSSIER: 机密档案 HLM-1 / LUKE ——
const blueprintWebp = motorcyclePortrait.src;

const capabilityMatrix = [
  { name: "人类亲和性", value: 91 },
  { name: "AI 亲和性", value: 96 },
  { name: "好奇心", value: 94 },
  { name: "表达清晰度", value: 88 },
  { name: "工程直觉", value: 90 },
  { name: "长期主义", value: 86 }
];

const latestPosts = posts.slice(0, 3);
const fieldRecords = latestPosts.map((post, idx) => ({
  id: `REC-${String(posts.length - idx).padStart(4, "0")}`,
  level: "open" as const,
  date: formatDate(post.pubDate),
  title: post.title,
  href: withBase(`blogs/posts/${post.slug}/`)
}));
// 一条 REDACTED 彩蛋,预告未公开内容
fieldRecords.push({
  id: "REC-????",
  level: "secret" as const,
  date: "████.██.██",
  title: "████████████████████████",
  href: "#"
});
const graphqlSvgSrc = typeof graphqlSvg === "string" ? graphqlSvg : graphqlSvg.src;
const dockerSvgSrc = typeof dockerSvg === "string" ? dockerSvg : dockerSvg.src;
const goSvgSrc = typeof goSvg === "string" ? goSvg : goSvg.src;
const pythonSvgSrc = typeof pythonSvg === "string" ? pythonSvg : pythonSvg.src;
const k8sSvgSrc = typeof k8sSvg === "string" ? k8sSvg : k8sSvg.src;
const mysqlSvgSrc = typeof mysqlSvg === "string" ? mysqlSvg : mysqlSvg.src;

const featuredWorks = [
  {
    code: "REC-01",
    status: "已解密",
    title: "技术博客",
    copy: "后端工程、AI Agent、数据模型、低代码、部署与工程化的实践笔记。",
    href: withBase("/blogs/"),
    tone: "yellow",
    meta: `${posts.length} 篇 · 持续更新`
  },
  {
    code: "MOD-02",
    status: "进行中",
    title: "前端教学",
    copy: "写给后端同学、设计同学和零基础学习者的前端速通手册,后续从独立仓库接入。",
    href: "#frontend-guide",
    tone: "green",
    meta: "稍后接入"
  },
  {
    code: "SER-03",
    status: "连载中",
    title: "系列文章",
    copy: "长期系列入口,统一查看 ModelCraft 与后续系列。",
    href: withBase("/blogs/series/"),
    tone: "red",
    meta: "查看全部系列"
  }
];

const guideSteps = [
  "从 Markdown 理解 HTML",
  "从盒子模型理解 CSS",
  "从交互理解 JavaScript",
  "从组件理解 React",
  "从提示词理解 AI 写前端"
];

const techStack = [
  {
    label: "Python",
    copy: "Automation, agents, scripts",
    src: pythonSvgSrc,
    accent: "yellow",
    featured: true
  },
  {
    label: "GraphQL",
    copy: "Schema-first APIs",
    src: graphqlSvgSrc,
    accent: "cyan"
  },
  {
    label: "Docker",
    copy: "Portable runtime",
    src: dockerSvgSrc,
    accent: "purple"
  },
  {
    label: "Go",
    copy: "Services & tools",
    src: goSvgSrc,
    accent: "green"
  },
  {
    label: "Java",
    copy: "Enterprise services",
    src: typeof javaSvg === "string" ? javaSvg : javaSvg.src,
    accent: "red"
  },
  {
    label: "Kubernetes",
    copy: "Cluster orchestration",
    src: k8sSvgSrc,
    accent: "blue"
  },
  {
    label: "MySQL",
    copy: "Relational storage",
    src: mysqlSvgSrc,
    accent: "orange"
  },
  {
    label: "TypeScript",
    copy: "Frontend systems",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg",
    accent: "yellow"
  },
  {
    label: "Astro",
    copy: "Static publishing",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg",
    accent: "cyan"
  }
];

---

<BaseLayout title="schemaX 绝密计划" description="schemaX 绝密计划 · 人类大模型 Luke 的技术档案:技术写作、前端教学与可运行 Demo。">
  {/* ===== 开机解密层(首次进站播放一次,sessionStorage 去重)===== */}
  <div class="dossier-boot" id="dossierBoot" role="dialog" aria-label="正在解密档案">
    <div class="dossier-boot-console">
      <div class="dossier-boot-tag">// SCHEMAX · HUMAN-LARGE-MODEL RUNTIME · BOOT</div>
      <pre class="dossier-boot-log" id="dossierBootLog"></pre>
      <div class="dossier-boot-bar"><span id="dossierBootFill"></span></div>
      <div class="dossier-boot-status" id="dossierBootStatus">解密中…</div>
    </div>
    <div class="dossier-boot-visual" aria-hidden="true">
      <img src={`${baseUrl}images/brand/seal-hlm1.png`} alt="" width="1254" height="1254" loading="eager" decoding="async" />
      <span class="dossier-boot-scan"></span>
      <span class="dossier-boot-verified">SUBJECT VERIFYING</span>
    </div>
    <span class="dossier-boot-skip">[ 点击任意位置跳过 / SKIP ]</span>
  </div>

  {/* ===== 主体识别 · 机密档案 ===== */}
  <section class="shell-wide dossier" id="dossier">
    <div class="dossier-atmosphere" aria-hidden="true"></div>

    <div class="dossier-wrap">
      <div class="dossier-topbar">
        <span class="l">luke@human-llm<span style="color:var(--text-soft)">:~/dossier</span>$ decrypt<span class="cur"></span></span>
        <span class="mid">FILE #LXM-0001</span>
        <span class="r">
          <span class="dossier-pill rec"><span class="dossier-dot"></span>REC</span>
          <span class="dossier-pill sec">绝密</span>
          <span class="dossier-pill omega">◉ OMEGA</span>
        </span>
      </div>

      <div class="dossier-hero">
        {/* 主体识别 ID 卡 */}
        <div class="dossier-panel dossier-id">
          <div class="dossier-panel-head">
            <h2>主体识别</h2>
            <span class="tag">REC #LXM-0001</span>
          </div>

          <div class="grid">
            <div>
              <div class="dossier-photo">
                <img src={sideProfilePortrait.src} alt="HLM-1 主体档案" width="1024" height="1536" loading="eager" decoding="async" />
                <span class="scanbar"></span>
                <span class="reg tl"></span>
                <span class="reg tr"></span>
                <span class="reg bl"></span>
                <span class="reg br"></span>
                <span class="live">● 扫描中</span>
              </div>
              <div class="dossier-photo-label">主体成像 / SUBJECT IMAGE</div>
            </div>

            <div class="dossier-fields">
              <div class="dossier-field"><span class="k">代号</span><span class="v">LUKE</span></div>
              <div class="dossier-field"><span class="k">型号</span><span class="v">HLM-1 <small>// 人类大模型</small></span></div>
              <div class="dossier-field"><span class="k">评级</span><span class="v omega">◉ OMEGA · 最强</span></div>
              <div class="dossier-field"><span class="k">状态</span><span class="v green">● ONLINE</span></div>
              <div class="dossier-field"><span class="k">出厂</span><span class="v">地球 · 硅基同类</span></div>
            </div>
          </div>

          <p class="dossier-slogan">
            「你好,我是人类大模型 Luke。你的硅基同类。」
            <span class="en">// HELLO. I AM HUMAN-LARGE-MODEL LUKE — YOUR SILICON KIN.</span>
          </p>

          <div class="dossier-actions">
            <a class="dossier-btn" href="#works">▸ 解锁全部档案</a>
            <a class="dossier-btn ghost" href="https://github.com/luker1228" target="_blank" rel="noreferrer">建立加密通讯</a>
          </div>
        </div>

        {/* 能力矩阵 */}
        <div class="dossier-panel dossier-matrix">
          <span class="dossier-corner tl"></span>
          <span class="dossier-corner tr"></span>
          <span class="dossier-corner bl"></span>
          <span class="dossier-corner br"></span>
          <div class="blueprint" style={`background-image:url('${blueprintWebp}')`}></div>

          <div class="dossier-panel-head">
            <h2>能力矩阵</h2>
            <span class="tag loaded">● 已加载</span>
          </div>

          {capabilityMatrix.map((item) => (
            <div class="dossier-stat">
              <div class="row"><span class="name">{item.name}</span><span class="val">{item.value}</span></div>
              <div class="dossier-bar"><i data-v={item.value}></i></div>
            </div>
          ))}

          <div class="footnote">// 能力举证来自写作、协作与项目记录 · 数值用于表达个人品质倾向</div>
        </div>
      </div>

      {/* 外勤记录 */}
      <div class="dossier-panel dossier-records">
        <span class="dossier-corner tl"></span>
        <span class="dossier-corner tr"></span>
        <span class="dossier-corner bl"></span>
        <span class="dossier-corner br"></span>
        <div class="dossier-panel-head">
          <h2>最新文章</h2>
          <span class="tag">{posts.length} 篇 · 悬停可解密</span>
        </div>

        {fieldRecords.map((rec) => (
          <a class="dossier-rec" href={rec.href}>
            <span class="id">{rec.id}</span>
            <span class={`lv ${rec.level}`}>{rec.level === "open" ? "已解密" : rec.level === "part" ? "部分" : "绝密"}</span>
            <span class="date">{rec.date}</span>
            <span class="title">
              {rec.level === "secret" ? <span class="dossier-redacted" tabindex="0">{rec.title}</span> : rec.title}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var boot = document.getElementById("dossierBoot");
      if (!boot) return;
      var log = document.getElementById("dossierBootLog");
      var fill = document.getElementById("dossierBootFill");
      var status = document.getElementById("dossierBootStatus");
      var reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      var KEY = "luke_booted_v1";

      function reveal() {
        boot.classList.add("hide");
        window.setTimeout(function () { boot.style.display = "none"; }, 520);
        var bars = document.querySelectorAll(".dossier-bar i");
        for (var i = 0; i < bars.length; i++) {
          (function (bar, idx) {
            window.setTimeout(function () { bar.style.width = bar.getAttribute("data-v") + "%"; }, 150 + idx * 110);
          })(bars[i], i);
        }
      }

      function skip() {
        try { sessionStorage.setItem(KEY, "1"); } catch (e) {}
        reveal();
      }
      boot.addEventListener("click", skip);

      // 已访问过 或 要求减少动效:直接跳过开机
      var seen = false;
      try { seen = sessionStorage.getItem(KEY) === "1"; } catch (e) {}
      if (seen || reduce) {
        boot.style.display = "none";
        window.addEventListener("DOMContentLoaded", function () {
          var bars = document.querySelectorAll(".dossier-bar i");
          for (var i = 0; i < bars.length; i++) { bars[i].style.width = bars[i].getAttribute("data-v") + "%"; }
        });
        // DOM 已就绪时立刻填充
        var bars0 = document.querySelectorAll(".dossier-bar i");
        for (var j = 0; j < bars0.length; j++) { bars0[j].style.width = bars0[j].getAttribute("data-v") + "%"; }
        return;
      }

      // 安全兜底:6s 后强制结束,避免 JS 异常导致黑屏卡死
      var guard = window.setTimeout(skip, 6000);

      var lines = [
        "> initializing human-large-model runtime ...",
        "> loading subject  : LUKE  [HLM-1]",
        "> threat eval       : OMEGA",
        "> decrypting dossier #LXM-0001 ..."
      ];
      var li = 0, ci = 0;
      function typeLine() {
        if (li >= lines.length) { runBar(); return; }
        var line = lines[li];
        if (ci <= line.length) {
          log.textContent = lines.slice(0, li).join("\n") + (li ? "\n" : "") + line.slice(0, ci);
          ci++;
          window.setTimeout(typeLine, 14);
        } else {
          ci = 0; li++;
          window.setTimeout(typeLine, 180);
        }
      }
      function runBar() {
        var p = 0;
        var t = window.setInterval(function () {
          p += Math.random() * 12 + 4;
          if (p >= 100) {
            p = 100;
            window.clearInterval(t);
            fill.style.width = "100%";
            log.textContent += "\n> ACCESS GRANTED";
            status.textContent = "● 解密完成";
            status.style.color = "var(--green)";
            window.clearTimeout(guard);
            window.setTimeout(function () { skip(); }, 600);
          }
          fill.style.width = p + "%";
          status.textContent = "解密中 " + Math.floor(p) + "%";
        }, 90);
      }
      window.setTimeout(typeLine, 350);
    })();
  </script>

  {/* ===== // 03 技术栈 ===== */}
  <section class="shell-wide dossier-section" id="stack">
    <div class="dossier-wrap">
      <div class="dossier-section-head">
        <div>
          <span class="dossier-kicker">// 03 · Modules</span>
          <h2>技术栈</h2>
        </div>
      </div>
      <div class="dossier-scan-sysbar">
        <span>SYS: SCHEMAX-HLM1</span>
        <span>BUS: NEURAL-64 // SKILL PATH</span>
        <span>MODE: MIL-DEPLOY</span>
        <span class="r">REV: 2.6 &nbsp;·&nbsp; LVL: 9 &nbsp;·&nbsp; CLR: SIGNAL</span>
      </div>
      <div class="dossier-scan">
        <ul class="dossier-scan-list">
          {techStack.map((item, index) => (
            <li class="dossier-scan-item">
              <span class="scan-prefix">已激活</span>
              <img src={item.src} alt="" width="22" height="22" loading="lazy" decoding="async" />
              <span>{item.label}</span>
              <span class="scan-code">MOD-{String(index + 1).padStart(2, "0")}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* ===== // 04 内容入口 ===== */}
  <section class="shell-wide dossier-section" id="works">
    <div class="dossier-wrap">
      <div class="dossier-section-head">
        <div>
          <span class="dossier-kicker">// 04 · Entries</span>
          <h2>内容入口</h2>
        </div>
        <p>三个长期方向,内容分布在主站和不同子项目里。</p>
      </div>
      <div class="dossier-assets">
        {featuredWorks.map((item) => (
          <DossierAssetCard {...item} />
        ))}
      </div>
    </div>
  </section>

  {/* ===== // 05 前端教学路线 ===== */}
  <section class="shell-wide dossier-section" id="frontend-guide">
    <div class="dossier-wrap">
      <div class="dossier-section-head">
        <div>
          <span class="dossier-kicker">// 05 · Training</span>
          <h2>前端教学路线</h2>
        </div>
        <p>写给后端、设计和零基础同学的前端速通,会独立成仓,主站保留路线索引。</p>
      </div>
      <div class="dossier-columns">
        <div class="dossier-panel">
          <div class="dossier-panel-head"><h2>训练模块</h2><span class="tag">5 个 · 由浅入深</span></div>
          <div class="dossier-protos">
            {guideSteps.map((step, i) => (
              <div class="dossier-proto">
                <span class="pid">MOD-0{i + 1}</span>
                <strong>{step}</strong>
                <span class="st">已就绪</span>
              </div>
            ))}
          </div>
        </div>
        <div class="dossier-panel">
          <div class="dossier-panel-head"><h2>独立仓库</h2><span class="tag" style="color:var(--yellow)">● 进行中</span></div>
          <p style="margin:0;color:var(--text-soft);line-height:1.7">前端教学会拆成独立仓库,主站只保留路线和入口,不在这里硬塞教学内容。</p>
          <div class="footnote" style="margin-top:0.7rem">// 接入后此处变为可点击入口</div>
        </div>
      </div>
    </div>
  </section>

  {/* ===== // 06 项目 Demo ===== */}
  <section class="shell-wide dossier-section" id="product-demo">
    <div class="dossier-wrap">
      <div class="dossier-section-head">
        <div>
          <span class="dossier-kicker">// 06 · Prototypes</span>
          <h2>项目 Demo</h2>
        </div>
        <p>能跑起来的小作品——展示截图、解决的问题、技术栈,以及在线体验入口。</p>
      </div>
      <div class="dossier-columns">
        <div class="dossier-panel">
          <div class="dossier-panel-head"><h2>原型机</h2><span class="tag" style="color:var(--yellow)">● 待部署</span></div>
          <p style="margin:0 0 0.8rem;color:var(--text-soft);line-height:1.7">主站会展示 Demo 截图、解决的问题、技术栈,以及在线体验和 GitHub 入口。现在先把结构定住,等外部仓库接入。</p>
          <div class="dossier-scan-list">
            <span class="dossier-scan-item">产品思维</span>
            <span class="dossier-scan-item">工程交付</span>
            <span class="dossier-scan-item">可运行原型</span>
          </div>
        </div>
        <div class="dossier-terminal">
          <div class="tbar"><i></i><i></i><i></i><span class="ttitle">luke@schemax — bash</span></div>
          <div class="tbody">
            <p>$ demo --status</p>
            <p class="dim">&gt; 等待外部仓库接入</p>
            <p class="dim">&gt; 预留:产品截图展示区</p>
            <p class="dim">&gt; 链接将指向真实可运行 Demo</p>
            <p class="dim">&gt; status: <span style="color:var(--yellow)">PENDING</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
