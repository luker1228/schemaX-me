---
import BaseLayout from "../layouts/BaseLayout.astro";
import DossierAssetCard from "../components/DossierAssetCard.astro";

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;

// —— 设计 DNA · THEME LAB ——
// 配色 token 来自 tokens.css 的实际值,字体/形状/motif 来自 dossier 设计系统

const palette = [
  { name: "INK", hex: "#171717", role: "页面主底 / Carbon Black", tone: "dark" },
  { name: "PAPER", hex: "#f6ead6", role: "正文纸面 / Aged Ivory", tone: "paper" },
  { name: "ACID", hex: "#ffd43b", role: "CTA / 编号 / Wanted Yellow", tone: "acid" },
  { name: "LIME", hex: "#00d26a", role: "在线 / 数据 / Phosphor Green", tone: "lime" },
  { name: "REDACT", hex: "#ff4d4d", role: "印章 / 警示 / Alert Red", tone: "red" }
];

const typeScale = [
  { token: "hero / display", size: "clamp(3rem, 8vw, 7rem)", weight: "700", sample: "人类大模型" },
  { token: "section head", size: "clamp(1.5rem, 3vw, 2.8rem)", weight: "700", sample: "外勤记录" },
  { token: "body", size: "15px ~ 17px", weight: "400", sample: "正文清晰耐读,中性无衬线。" },
  { token: "mono / meta", size: "11px ~ 13px", weight: "700", sample: "STATUS: ONLINE" },
  { token: "big numeral", size: "clamp(4rem, 10vw, 10rem)", weight: "900", sample: "03" }
];

const grammar = [
  {
    code: "MOD-01",
    title: "CYBERPUNK",
    desc: "扫描、荧光、系统警示、机械编号、危险感、在线感。",
    examples: ["扫描条", "状态灯闪烁", "荧光 acid", "REC 印章"],
    tone: "red"
  },
  {
    code: "MOD-02",
    title: "ZINE",
    desc: "撞版、编号、边注、拼贴、裁切式标题、低保真印刷感。",
    examples: ["大编号", "脚注边注", "issue tag", "局部出血"],
    tone: "yellow"
  },
  {
    code: "MOD-03",
    title: "RETROUI",
    desc: "厚边框、硬阴影、凸起按钮、窗口栏、状态条、旧机器界面。",
    examples: ["硬阴影 4px", "厚边框 panel", "塑料键帽按钮", "角标对位"],
    tone: "green"
  }
];
---

<BaseLayout
  title="设计 DNA · THEME LAB · Luke"
  description="Luke 站点的设计 DNA——cyberpunk + zine + retroui 三层语法、配色 token、字体阶梯、motif 装备清单,以 Theme Lab 形式自我指涉展示。"
>
  <div class="design-dna-page dossier">

    {/* ===== HERO · THEME LAB ===== */}
    <section class="shell-wide design-dna-hero" id="top">
      <div class="design-dna-hero-grid">
        <div class="design-dna-hero-meta">
          <span class="design-dna-pill">THEME LAB</span>
          <span class="design-dna-pill omega">ISSUE 03</span>
        </div>

        <h1 class="design-dna-title">
          设计 <span class="design-dna-title-accent">DNA</span>
        </h1>

        <p class="design-dna-tagline">
          // 9 个轴 · 一套语法 · 这页就是它自己的样本。
        </p>

        <p class="design-dna-lead">
          外层像系统,内层像杂志,交互像旧机器。配色 token、字体阶梯、形状规则、motif 装备——全部以实物 demo 呈现,不靠描述。
        </p>

        <div class="design-dna-hero-actions">
          <a class="dossier-btn" href="#colors">▸ 探索色板</a>
          <a class="dossier-btn ghost" href="#components">查看组件</a>
        </div>
      </div>
    </section>

    {/* ===== §1 COLORS · 配色 token ===== */}
    <section class="shell-wide dossier-section design-dna-section" id="colors">
      <div class="dossier-section-head">
        <div>
          <span class="dossier-kicker">§1 · colors</span>
          <h2>配色 token</h2>
        </div>
        <p>六个语义色,黑灰底 65% / 纸白 15% / 荧光强调 20%。acid + lime 是默认双核,redact 只打点。</p>
      </div>

      <div class="dossier-panel design-dna-panel">
        <div class="dossier-panel-head">
          <h2>PALETTE · 6 TOKENS</h2>
          <span class="tag loaded">● 已加载</span>
        </div>

        <ul class="design-dna-swatch-list">
          {palette.map((c) => (
            <li class={`design-dna-swatch tone-${c.tone}`}>
              <span class="design-dna-swatch-chip" style={`--swatch:${c.hex}`}></span>
              <div class="design-dna-swatch-body">
                <span class="design-dna-swatch-name">{c.name}</span>
                <span class="design-dna-swatch-hex">{c.hex}</span>
                <span class="design-dna-swatch-role">{c.role}</span>
                <span class={`design-dna-swatch-demo tone-${c.tone}`}>BTN</span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    {/* ===== §2 TYPE · 字体 specimen ===== */}
    <section class="shell-wide dossier-section design-dna-section" id="type">
      <div class="dossier-section-head">
        <div>
          <span class="dossier-kicker">§2 · type</span>
          <h2>字体 specimen</h2>
        </div>
        <p>中文标题走粗黑工业感,正文走中性无衬线,英文辅助走等宽体。标题要有压迫感,正文要能喘气。</p>
      </div>

      <div class="dossier-panel design-dna-panel">
        <div class="dossier-panel-head">
          <h2>TYPE · SPECIMEN</h2>
          <span class="tag">--font-display / --font-mono</span>
        </div>

        <div class="design-dna-specimen-top">
          <div class="design-dna-specimen-glyph" aria-hidden="true">Aa</div>
          <div class="design-dna-specimen-info">
            <div class="design-dna-specimen-display">人类大模型 LUKE</div>
            <div class="design-dna-specimen-mono">luke@human-llm:~$ make page --style=dossier</div>
          </div>
        </div>

        <div class="design-dna-specimen-marker">
          // 一个 section 内最多一个「极端排版动作」。英文不是翻译件,而是版面节奏器。
        </div>

        <div class="design-dna-type-table">
          <div class="design-dna-type-row design-dna-type-head">
            <span>TOKEN</span><span>SIZE</span><span>WEIGHT</span><span>SAMPLE</span>
          </div>
          {typeScale.map((row) => (
            <div class="design-dna-type-row">
              <span class="design-dna-type-token">{row.token}</span>
              <span class="design-dna-type-size">{row.size}</span>
              <span class="design-dna-type-weight">{row.weight}</span>
              <span class="design-dna-type-sample">{row.sample}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ===== §3 SHAPE · 边框 / 圆角 / 阴影 ===== */}
    <section class="shell-wide dossier-section design-dna-section" id="shape">
      <div class="dossier-section-head">
        <div>
          <span class="dossier-kicker">§3 · shape</span>
          <h2>边框 · 圆角 · 阴影</h2>
        </div>
        <p>卡片和控件 4px 圆角，pill tag 用 9999px，其余全部直角。阴影是错位印刷感，不是漂浮卡片——允许 4px 4px 0 #000，禁止柔雾。</p>
      </div>

      <div class="design-dna-shape-grid">
        <div class="dossier-panel design-dna-shape-card">
          <div class="design-dna-shape-label">BORDER · 厚边框</div>
          <div class="design-dna-shape-stack">
            <span class="design-dna-shape-demo border-thin">1px solid</span>
            <span class="design-dna-shape-demo border-mid">2px solid</span>
            <span class="design-dna-shape-demo border-thick">3px solid</span>
          </div>
          <div class="design-dna-shape-note">默认 1px,强调位用 2-3px</div>
        </div>

        <div class="dossier-panel design-dna-shape-card">
          <div class="design-dna-shape-label">SHADOW · 硬阴影</div>
          <div class="design-dna-shape-stack">
            <span class="design-dna-shape-demo shadow-sm">4px offset</span>
            <span class="design-dna-shape-demo shadow-md">8px offset</span>
            <span class="design-dna-shape-demo shadow-lg">12px offset</span>
          </div>
          <div class="design-dna-shape-note">错位印刷,不是浮层</div>
        </div>

        <div class="dossier-panel design-dna-shape-card">
          <div class="design-dna-shape-label">RADIUS · 圆角</div>
          <div class="design-dna-shape-stack">
            <span class="design-dna-shape-demo radius-0">0</span>
            <span class="design-dna-shape-demo radius-sm">4px (cap)</span>
            <span class="design-dna-shape-demo radius-pill">9999px (pill only)</span>
          </div>
          <div class="design-dna-shape-note">卡片 / 控件 4px，pill tag 9999px，其余 0</div>
        </div>
      </div>
    </section>

    {/* ===== §4 PATTERN · motif 装备清单 ===== */}
    <section class="shell-wide dossier-section design-dna-section" id="pattern">
      <div class="dossier-section-head">
        <div>
          <span class="dossier-kicker">§4 · pattern</span>
          <h2>motif 装备清单</h2>
        </div>
        <p>每个 motif 就是它自己的实物演示——不靠描述,靠触感。</p>
      </div>

      <div class="design-dna-motif-grid">
        <div class="design-dna-motif-cell">
          <div class="design-dna-motif-label">硬阴影 · HARD SHADOW</div>
          <span class="design-dna-motif-demo with-shadow">4px 4px 0 acid</span>
        </div>
        <div class="design-dna-motif-cell restricted">
          <div class="design-dna-motif-label">
            角标对位 · REGISTRATION
            <span class="design-dna-motif-tag">ID 卡专属</span>
          </div>
          <span class="design-dna-motif-demo with-corners">
            <span class="dossier-corner tl"></span>
            <span class="dossier-corner tr"></span>
            <span class="dossier-corner bl"></span>
            <span class="dossier-corner br"></span>
            四角 L 形
          </span>
          <p class="design-dna-motif-note">⚠ 铁律:仅首页 §2 主体识别卡(.dossier-id)可用,其它任何位置禁止现场渲染。</p>
        </div>
        <div class="design-dna-motif-cell">
          <div class="design-dna-motif-label">状态灯 · STATUS DOT</div>
          <span class="design-dna-motif-demo with-blink"><span class="dossier-dot"></span>● ONLINE</span>
        </div>
        <div class="design-dna-motif-cell">
          <div class="design-dna-motif-label">印章 · STAMP</div>
          <span class="design-dna-motif-demo with-stamp">
            <span class="dossier-stamp s1">CLASSIFIED</span>
            贴角红章
          </span>
        </div>
        <div class="design-dna-motif-cell">
          <div class="design-dna-motif-label">涂黑 · REDACTED</div>
          <span class="design-dna-motif-demo">
            <span class="dossier-redacted">机密内容 hover 揭示</span>
          </span>
        </div>
        <div class="design-dna-motif-cell">
          <div class="design-dna-motif-label">扫描条 · SCANBAR</div>
          <span class="design-dna-motif-demo with-scan">
            <span class="design-dna-scanbar"></span>
            CRT 扫描
          </span>
        </div>
      </div>
    </section>

    {/* ===== §5 COMPONENTS · 组件样本(首页真实组件,共享同一份 dossier class) ===== */}
    <section class="shell-wide dossier-section design-dna-section" id="components">
      <div class="dossier-section-head">
        <div>
          <span class="dossier-kicker">§5 · components</span>
          <h2>组件样本</h2>
        </div>
        <p>下面每个组件都是首页正在使用的同款——同一份 class、同一份样式,没有另写 demo。改这里就是改首页。</p>
      </div>

      <div class="design-dna-comp-list">

        {/* —— C1 · dossier-btn 按钮 —— */}
        <article class="dossier-panel design-dna-comp-card">
          <div class="design-dna-comp-head">
            <div class="design-dna-comp-label">C1 · <code>.dossier-btn</code></div>
            <span class="design-dna-comp-where">§1 hero CTA</span>
          </div>
          <div class="design-dna-comp-body">
            <div class="design-dna-btn-row">
              <a class="dossier-btn" href="#components">▸ Primary</a>
              <a class="dossier-btn ghost" href="#components">Secondary</a>
            </div>
            <p class="design-dna-comp-note">// 主按钮 acid 黄底硬阴影,ghost 副按钮透明描边。<code>:hover</code> 位移 2px。</p>
          </div>
        </article>

        {/* —— C2 · dossier-panel + head + tag 容器 —— */}
        <article class="dossier-panel design-dna-comp-card">
          <div class="design-dna-comp-head">
            <div class="design-dna-comp-label">C2 · <code>.dossier-panel</code> + <code>.dossier-panel-head</code></div>
            <span class="design-dna-comp-where">§2 / §4</span>
          </div>
          <div class="design-dna-comp-body">
            <div class="dossier-panel design-dna-nested-panel">
              <div class="dossier-panel-head">
                <h2>SUBJECT</h2>
                <span class="tag loaded">● 已加载</span>
              </div>
              <p class="design-dna-comp-note" style="margin:0;">// 8×8 硬阴影 + 1px 墨水边 + 角标对位 + 虚线 head 分隔</p>
            </div>
          </div>
        </article>

        {/* —— C3 · dossier-photo 扫描框 —— */}
        <article class="dossier-panel design-dna-comp-card">
          <div class="design-dna-comp-head">
            <div class="design-dna-comp-label">C3 · <code>.dossier-photo</code> 扫描框</div>
            <span class="design-dna-comp-where">§2 ID 卡</span>
          </div>
          <div class="design-dna-comp-body">
            <div class="dossier-photo design-dna-demo-photo">
              <img src={withBase("images/brand/hlm1-side-profile.png")} alt="主体样本" width="400" height="600" loading="lazy" />
              <span class="scanbar"></span>
              <span class="reg tl"></span>
              <span class="reg tr"></span>
              <span class="reg bl"></span>
              <span class="reg br"></span>
              <span class="live">● 扫描中</span>
            </div>
            <p class="design-dna-comp-note">// 红色 scanbar 垂直扫描 + 四角 reg 对位 + 底部 live 状态</p>
          </div>
        </article>

        {/* —— C4 · dossier-field 字段表 —— */}
        <article class="dossier-panel design-dna-comp-card">
          <div class="design-dna-comp-head">
            <div class="design-dna-comp-label">C4 · <code>.dossier-field</code> 字段表</div>
            <span class="design-dna-comp-where">§2 ID 卡</span>
          </div>
          <div class="design-dna-comp-body">
            <div class="dossier-fields">
              <div class="dossier-field"><span class="k">代号</span><span class="v">LUKE</span></div>
              <div class="dossier-field"><span class="k">评级</span><span class="v omega">◉ OMEGA</span></div>
              <div class="dossier-field"><span class="k">状态</span><span class="v green">● ONLINE</span></div>
            </div>
            <p class="design-dna-comp-note">// mono key + 值支持 <code>.v.green</code> / <code>.v.omega</code> 状态色</p>
          </div>
        </article>

        {/* —— C5 · dossier-stat 能力矩阵条 —— */}
        <article class="dossier-panel design-dna-comp-card">
          <div class="design-dna-comp-head">
            <div class="design-dna-comp-label">C5 · <code>.dossier-stat</code> + <code>.dossier-bar</code></div>
            <span class="design-dna-comp-where">§2 能力矩阵</span>
          </div>
          <div class="design-dna-comp-body">
            <div class="dossier-stat">
              <div class="row">
                <span class="name">好奇心</span>
                <span class="val">94</span>
              </div>
              <div class="dossier-bar"><i style="width:94%"></i></div>
            </div>
            <div class="dossier-stat">
              <div class="row">
                <span class="name">工程直觉</span>
                <span class="val">90</span>
              </div>
              <div class="dossier-bar"><i style="width:90%"></i></div>
            </div>
            <p class="design-dna-comp-note">// 黄色条纹填充条 + mono 数值,首页由 JS 做 count-up 生长</p>
          </div>
        </article>

        {/* —— C6 · dossier-scan-item 技术栈扫描行 —— */}
        <article class="dossier-panel design-dna-comp-card">
          <div class="design-dna-comp-head">
            <div class="design-dna-comp-label">C6 · <code>.dossier-scan-item</code> 扫描行</div>
            <span class="design-dna-comp-where">§3 技术栈</span>
          </div>
          <div class="design-dna-comp-body">
            <div class="dossier-scan">
              <ul class="dossier-scan-list">
                <li class="dossier-scan-item">
                  <span class="scan-code">MOD-01</span>
                  <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg" alt="" width="18" height="18" loading="lazy" />
                  <span>PYTHON</span>
                  <span class="scan-prefix">已激活</span>
                </li>
                <li class="dossier-scan-item">
                  <span class="scan-code">MOD-02</span>
                  <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg" alt="" width="18" height="18" loading="lazy" />
                  <span>TYPESCRIPT</span>
                  <span class="scan-prefix">已激活</span>
                </li>
              </ul>
            </div>
            <p class="design-dna-comp-note">// 黄色 MOD 编号 + 图标 + 名称 + 绿色激活 chip,带横向扫描光带</p>
          </div>
        </article>

        {/* —— C7 · dossier-rec 博客记录行 —— */}
        <article class="dossier-panel design-dna-comp-card">
          <div class="design-dna-comp-head">
            <div class="design-dna-comp-label">C7 · <code>.dossier-rec</code> 记录行</div>
            <span class="design-dna-comp-where">§4 博客</span>
          </div>
          <div class="design-dna-comp-body">
            <div class="dossier-panel dossier-records design-dna-nested-panel">
              <a class="dossier-rec" href="#components">
                <span class="id">REC-0042</span>
                <span class="lv open">已解密</span>
                <span class="date">2026-07-12</span>
                <span class="title">样本文章标题</span>
              </a>
              <a class="dossier-rec" href="#components">
                <span class="id">REC-0041</span>
                <span class="lv open">已解密</span>
                <span class="date">2026-06-30</span>
                <span class="title">另一篇外勤记录</span>
              </a>
            </div>
            <p class="design-dna-comp-note">// id 黄 mono + 状态 chip + 日期 + 标题,<code>.lv.open/.part/.secret</code> 三态</p>
          </div>
        </article>

        {/* —— C8 · DossierAssetCard 课程卡(真实 Astro 组件) —— */}
        <article class="dossier-panel design-dna-comp-card">
          <div class="design-dna-comp-head">
            <div class="design-dna-comp-label">C8 · <code>&lt;DossierAssetCard /&gt;</code> 组件</div>
            <span class="design-dna-comp-where">§5 课程</span>
          </div>
          <div class="design-dna-comp-body design-dna-asset-demo">
            <DossierAssetCard
              code="CRS-DEMO"
              status="已上线"
              title="样本手册"
              copy="这是 DossierAssetCard 组件的真实渲染,与首页课程区共用同一份代码。"
              meta="查看手册"
              href="#components"
              tone="green"
            />
            <p class="design-dna-comp-note">// 唯一真正的 Astro 组件:head(code+status) / body(title+desc) / foot(meta)</p>
          </div>
        </article>

        {/* —— C9 · dossier-section-head section 头 —— */}
        <article class="dossier-panel design-dna-comp-card">
          <div class="design-dna-comp-head">
            <div class="design-dna-comp-label">C9 · <code>.dossier-section-head</code></div>
            <span class="design-dna-comp-where">所有 section</span>
          </div>
          <div class="design-dna-comp-body">
            <div class="dossier-section-head" style="margin:0;">
              <div>
                <span class="dossier-kicker">// KICKER</span>
                <h2 style="margin:0;font-size:1.4rem;">SECTION 标题</h2>
              </div>
              <p style="margin:0;max-width:18rem;">本页所有 section 的头部都由这个组件渲染。</p>
            </div>
            <p class="design-dna-comp-note">// kicker 小字 + h2 display 大写 + 右侧描述,非对称两端对齐</p>
          </div>
        </article>

      </div>
    </section>


    {/* ===== §6 GRAMMAR · 三层语法 ===== */}
    <section class="shell-wide dossier-section design-dna-section" id="grammar">
      <div class="dossier-section-head">
        <div>
          <span class="dossier-kicker">§6 · grammar</span>
          <h2>三层语法</h2>
        </div>
        <p>外层像系统,内层像杂志,交互像旧机器——三种语言叠加,不是任一单独成立。</p>
      </div>

      <div class="design-dna-grammar-grid">
        {grammar.map((g) => (
