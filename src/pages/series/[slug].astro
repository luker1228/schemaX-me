---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getAllPosts, getPostsBySeries, getSeriesSlug } from "../../lib/content";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const seriesNames = Array.from(new Set(posts.map((post) => post.series).filter((series): series is string => Boolean(series))));

  return seriesNames.map((series) => ({
    params: { slug: getSeriesSlug(series) },
    props: { series }
  }));
}

const { series } = Astro.props;
const posts = await getPostsBySeries(series);
---

<BaseLayout title={`${series} | Luke's AI Hub`} description={`${series} 系列文章目录。`}>
  <section class="shell article-shell">
    <div class="section-head">
      <h2>{series}</h2>
      <p>按时间倒序查看这个系列下的全部文章。</p>
    </div>

    <div class="recent-list">
      {posts.map((post) => (
        <a class="recent-item" href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}posts/${post.slug}/`}>
          <span class="recent-date">{formatDate(post.pubDate)}</span>
          <div class="recent-body">
            <strong>{post.title}</strong>
            <p>{post.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
