---
// Dossier 风格桥接顶栏 —— 自包含样式(课程页只加载 howto/styles.css,没有 global.css 的
// dossier token/类/blink keyframe,所以这里全部硬编码,不依赖外部)。
import DecodeOverlay from "./_DecodeOverlay.astro";
interface Props {
  crumb?: string;
}
const { crumb = "" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const withBase = (p: string) => `${baseUrl}${p.replace(/^\//, "")}`;
const hubHref = withBase("howto/");
const pathStr = crumb ? `howto/frontend/${crumb}` : "howto/frontend";
---

<DecodeOverlay />
<div class="db" role="navigation" aria-label="战术手册导航">
  <span class="db-left">
    luke@human-llm<span class="db-muted">:~/{pathStr}</span>$
    <span class="db-dot" aria-hidden="true"></span>ONLINE
  </span>
  <a class="db-back" href={hubHref}>◂ 返回战术手册</a>
</div>

<style>
  .db {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 8px 14px;
    background: #0c0f0d;
    border-bottom: 2px solid #000;
    color: #22ff88;
    font-family: "IBM Plex Mono", "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
  }
  .db-left {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .db-muted {
    color: #9c9384;
  }
  .db-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    background: #22ff88;
    border-radius: 50%;
    animation: db-blink 1.2s steps(1) infinite;
  }
  .db-back {
    border: 1.5px solid #ffd43b;
    color: #ffd43b;
    padding: 3px 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: background 140ms ease, color 140ms ease;
  }
  .db-back:hover {
    background: #ffd43b;
    color: #0c0f0d;
  }
  @keyframes db-blink {
    50% {
      opacity: 0;
    }
  }
</style>
