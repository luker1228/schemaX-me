---
import { DeployIndexPage } from "../../../howto/components/deploy/deploy-index-page.jsx";
import "../../../howto/styles.css";
import DossierBridge from "./_DossierBridge.astro";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>部署战术手册</title>
    <script is:inline>
      (function () {
        try {
          var state = JSON.parse(sessionStorage.getItem("howto-manual-transition") || "null");
          var currentPath = window.location.pathname.replace(/\/+$/, "/");
          if (
            state &&
            state.href &&
            state.expiresAt &&
            state.expiresAt >= Date.now() &&
            state.href.replace(/^https?:\/\/[^/]+/, "").replace(/\/+$/, "/") === currentPath
          ) {
            document.documentElement.classList.add("arrival-pending");
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div data-arrival-content>
      <DossierBridge crumb="" />
    </div>

    <div class="arrival-mask" id="arrivalMask" aria-hidden="true">
      <div class="arrival-shell">
        <div class="arrival-head">
          <span class="arrival-label">BIO ID SCAN</span>
          <span class="arrival-state">ACCESS RELEASED</span>
        </div>
        <div class="arrival-grid">
          <div class="arrival-frame">
            <i class="arrival-corner tl"></i>
            <i class="arrival-corner tr"></i>
            <i class="arrival-corner bl"></i>
            <i class="arrival-corner br"></i>
            <div class="arrival-noise"></div>
            <div class="arrival-target">
              <div class="arrival-ring ring-a"></div>
              <div class="arrival-ring ring-b"></div>
              <div class="arrival-ring ring-c"></div>
              <div class="arrival-silhouette">
                <i class="arrival-head-shape"></i>
                <i class="arrival-shoulders"></i>
              </div>
              <div class="arrival-beam"></div>
            </div>
            <span class="arrival-percent" id="arrivalPercent">0%</span>
            <span class="arrival-success">LLM 识别成功</span>
          </div>

          <div class="arrival-side">
            <div class="arrival-dossier">
              <span class="arrival-kicker">TARGET DOSSIER</span>
              <strong id="arrivalTitle">部署战术手册</strong>
              <p id="arrivalPath">&gt; ACCESS // ./howto/deploy</p>
            </div>
            <div class="arrival-log">
              <p>&gt; FACE VECTOR MATCHED</p>
              <p>&gt; CLEARANCE LEVEL // 已解密</p>
              <p>&gt; MANUAL UNSEALED</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var mask = document.getElementById("arrivalMask");
        if (!mask) return;
        var reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        var title = document.getElementById("arrivalTitle");
        var path = document.getElementById("arrivalPath");
        var percent = document.getElementById("arrivalPercent");
        var state = null;
        try {
          state = JSON.parse(sessionStorage.getItem("howto-manual-transition") || "null");
        } catch (e) {}
        var currentPath = window.location.pathname.replace(/\/+$/, "/");
        if (
          !state ||
          !state.href ||
          !state.expiresAt ||
          state.expiresAt < Date.now() ||
          state.href.replace(/^https?:\/\/[^/]+/, "").replace(/\/+$/, "/") !== currentPath
        ) {
          mask.remove();
          return;
        }
        try {
          sessionStorage.removeItem("howto-manual-transition");
        } catch (e) {}
        if (title && state.title) title.textContent = state.title;
        if (path && state.path) path.textContent = "> ACCESS // ./" + state.path;
        if (reduce) {
          document.documentElement.classList.remove("arrival-pending");
          mask.remove();
          return;
        }
        document.documentElement.classList.add("arrival-active");
        requestAnimationFrame(function () {
          mask.classList.add("is-active");
          window.setTimeout(function () {
            mask.classList.add("is-armed");
            window.setTimeout(function () {
              mask.classList.add("is-opening");
              window.setTimeout(function () {
                var current = 0;
                var timer = window.setInterval(function () {
                  current += 4;
                  if (current >= 100) {
                    current = 100;
                    window.clearInterval(timer);
                    mask.classList.add("is-verified");
                  }
                  if (percent) percent.textContent = current + "%";
                }, 58);
              }, 120);
              window.setTimeout(function () {
                mask.classList.add("is-closing");
                window.setTimeout(function () {
                  mask.classList.add("is-done");
                  document.documentElement.classList.remove("arrival-pending");
                  document.documentElement.classList.remove("arrival-active");
                  window.setTimeout(function () {
                    mask.remove();
                  }, 240);
                }, 760);
              }, 1700);
            }, 260);
          }, 40);
        });
      })();
    </script>

    <div data-arrival-content>
      <DeployIndexPage client:load />
    </div>
  </body>
</html>

<style>
  :global(html.arrival-pending) {
    background: #0c0f0d;
  }
  :global(html.arrival-active),
  :global(html.arrival-active body) {
    overflow: hidden;
  }
  :global(html.arrival-pending body) {
    background: #0c0f0d;
  }
  :global(html.arrival-pending [data-arrival-content]) {
    opacity: 0;
  }
  :global(html.arrival-active .brand-mark) {
    opacity: 0;
  }
  [data-arrival-content] {
    transition: opacity 320ms ease 180ms;
  }
  .arrival-mask {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    padding: 2rem;
    background: var(--dossier-boot-bg);
    color: var(--phosphor);
    font-family: "IBM Plex Mono", "JetBrains Mono", ui-monospace, monospace;
    opacity: 0;
    visibility: hidden;
    overflow: hidden;
    transition: opacity 220ms ease, visibility 220ms ease;
  }
  .arrival-mask::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    z-index: 4;
    width: 100%;
    height: 1px;
    background: rgba(152, 255, 201, 0.34);
    box-shadow: 0 0 18px rgba(34, 255, 136, 0.32);
    opacity: 1;
    transform: translateY(-50%);
    transition: opacity 420ms ease;
  }
  .arrival-mask.is-opening::before {
    opacity: 0;
  }
  .arrival-mask.is-active {
    opacity: 1;
    visibility: visible;
  }
  :global(html.arrival-pending) .arrival-mask {
    opacity: 1;
    visibility: visible;
  }
  .arrival-mask.is-done {
    opacity: 0;
    visibility: hidden;
    transition: opacity 220ms ease, visibility 220ms ease;
  }
  .arrival-shell {
    width: min(760px, 100%);
    position: relative;
    z-index: 2;
    padding: clamp(1.1rem, 3vw, 1.6rem);
    border: 1px solid rgba(74, 255, 176, 0.28);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(20, 54, 36, 0.72), rgba(7, 14, 11, 0.9)),
      rgba(5, 10, 8, 0.94);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04) inset,
      0 24px 80px rgba(0, 0, 0, 0.42),
      0 0 48px rgba(34, 255, 136, 0.12);
    overflow: hidden;
    opacity: 0;
    transform: translateY(10px) scale(0.985);
    transition: opacity 360ms ease 80ms, transform 520ms cubic-bezier(0.2, 0.78, 0.18, 1) 80ms;
  }
  .arrival-mask.is-armed .arrival-shell {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .arrival-mask.is-closing .arrival-shell {
    opacity: 0;
    transform: translateY(-8px) scale(0.985);
    transition-delay: 0ms;
  }
  .arrival-shell::before,
  .arrival-shell::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .arrival-shell::before {
    background:
      radial-gradient(circle at top right, rgba(34, 255, 136, 0.18), transparent 28%),
      linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
    opacity: 0.8;
  }
  .arrival-shell::after {
    background: repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.03) 0 1px, transparent 1px 4px);
    mix-blend-mode: screen;
    opacity: 0.3;
  }
  .arrival-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .arrival-label {
    color: rgba(230, 255, 244, 0.74);
  }
  .arrival-state {
    color: #ffd43b;
  }
  .arrival-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(260px, 0.95fr);
    gap: 1.15rem;
    align-items: stretch;
  }
  .arrival-frame,
  .arrival-side {
    position: relative;
    border: 1px solid rgba(74, 255, 176, 0.22);
    border-radius: 20px;
    background: rgba(6, 13, 10, 0.7);
  }
  .arrival-frame {
    min-height: 360px;
    padding: 1rem;
    overflow: hidden;
  }
  .arrival-corner {
    position: absolute;
    width: 22px;
    height: 22px;
    border-color: #7dffbf;
    border-style: solid;
    border-width: 0;
    opacity: 0.88;
  }
  .arrival-corner.tl {
    top: 12px;
    left: 12px;
    border-top-width: 2px;
    border-left-width: 2px;
  }
  .arrival-corner.tr {
    top: 12px;
    right: 12px;
    border-top-width: 2px;
    border-right-width: 2px;
  }
  .arrival-corner.bl {
    bottom: 12px;
    left: 12px;
    border-bottom-width: 2px;
    border-left-width: 2px;
  }
  .arrival-corner.br {
    right: 12px;
    bottom: 12px;
    border-right-width: 2px;
    border-bottom-width: 2px;
  }
  .arrival-noise {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(34, 255, 136, 0.05), transparent 24%, transparent 76%, rgba(34, 255, 136, 0.06)),
      repeating-linear-gradient(90deg, rgba(34, 255, 136, 0.06) 0 1px, transparent 1px 48px),
      repeating-linear-gradient(0deg, rgba(34, 255, 136, 0.05) 0 1px, transparent 1px 40px);
    opacity: 0.65;
  }
  .arrival-target {
    position: relative;
    min-height: 328px;
    display: grid;
    place-items: center;
  }
  .arrival-ring {
    position: absolute;
    border: 1px solid rgba(122, 255, 193, 0.34);
    border-radius: 50%;
  }
  .arrival-ring.ring-a {
    width: 210px;
    height: 210px;
  }
  .arrival-ring.ring-b {
    width: 154px;
    height: 154px;
  }
  .arrival-ring.ring-c {
    width: 282px;
    height: 282px;
    border-style: dashed;
    opacity: 0.6;
    animation: arrival-ring-spin 3200ms linear infinite;
  }
  .arrival-beam {
    position: absolute;
    left: 10%;
    right: 10%;
    top: 0;
    height: 72px;
    background: linear-gradient(180deg, rgba(144, 255, 204, 0), rgba(144, 255, 204, 0.42), rgba(144, 255, 204, 0));
    filter: blur(2px);
    transform: translateY(-120%);
    animation: arrival-beam-scan 1800ms ease-in-out 120ms forwards;
  }
  .arrival-silhouette {
    position: relative;
    width: 168px;
    height: 208px;
  }
  .arrival-head-shape,
  .arrival-shoulders {
    position: absolute;
    left: 50%;
    display: block;
    transform: translateX(-50%);
    background: linear-gradient(180deg, rgba(194, 255, 223, 0.92), rgba(40, 255, 144, 0.16));
    box-shadow: 0 0 18px rgba(81, 255, 166, 0.16);
  }
  .arrival-head-shape {
    top: 8px;
    width: 70px;
    height: 82px;
    border-radius: 40px 40px 34px 34px;
  }
  .arrival-shoulders {
    bottom: 12px;
    width: 164px;
    height: 124px;
    border-radius: 72px 72px 28px 28px;
    clip-path: polygon(7% 100%, 19% 38%, 34% 18%, 50% 10%, 66% 18%, 81% 38%, 93% 100%);
  }
  .arrival-percent {
    position: absolute;
    right: 18px;
    bottom: 18px;
    color: #98ffc9;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    animation: arrival-percent-flicker 900ms steps(2, end) 240ms infinite;
  }
  .arrival-success {
    position: absolute;
    left: 18px;
    bottom: 18px;
    padding: 0.36rem 0.65rem;
    border: 1px solid rgba(152, 255, 201, 0.42);
    background: rgba(2, 7, 4, 0.72);
    color: #effff5;
    font-size: clamp(1rem, 2.4vw, 1.22rem);
    font-weight: 700;
    letter-spacing: 0.1em;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 180ms ease, transform 180ms ease;
  }
  .arrival-mask.is-verified .arrival-success {
    opacity: 1;
    transform: translateY(0);
  }
  .arrival-side {
    display: grid;
    gap: 1rem;
    padding: 1rem;
    align-content: center;
  }
  .arrival-kicker {
    color: rgba(236, 255, 246, 0.58);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .arrival-dossier {
    display: grid;
    gap: 0.45rem;
  }
  .arrival-dossier strong {
    color: #effff5;
    font-size: clamp(1.15rem, 3vw, 1.5rem);
    line-height: 1.05;
    letter-spacing: 0.02em;
  }
  .arrival-dossier p {
    margin: 0;
    color: rgba(152, 255, 201, 0.9);
    font-size: 0.82rem;
    line-height: 1.6;
  }
  .arrival-log {
    width: 100%;
    color: #22ff88;
    font-size: 0.78rem;
    line-height: 1.7;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(74, 255, 176, 0.15);
    border-radius: 14px;
    background: rgba(9, 18, 13, 0.68);
  }
  .arrival-log p {
    margin: 0;
    opacity: 0;
    animation: arrival-line 220ms ease forwards;
  }
  .arrival-log p:nth-child(2) {
    animation-delay: 120ms;
  }
  .arrival-log p:nth-child(3) {
    animation-delay: 240ms;
  }
  @keyframes arrival-line {
    to {
      opacity: 1;
    }
  }
  @keyframes arrival-ring-spin {
    to {
      transform: rotate(1turn);
    }
  }
  @keyframes arrival-beam-scan {
    to {
      transform: translateY(360px);
    }
  }
  @keyframes arrival-percent-flicker {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.56;
    }
  }
  @media (max-width: 820px) {
    .arrival-grid {
      grid-template-columns: 1fr;
    }
    .arrival-frame {
      min-height: 300px;
    }
    .arrival-target {
      min-height: 268px;
    }
    .arrival-ring.ring-c {
      width: 236px;
      height: 236px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .arrival-mask,
    .arrival-ring.ring-c,
    .arrival-beam,
    .arrival-log p {
      animation: none;
      transition: none;
    }
  }
</style>
