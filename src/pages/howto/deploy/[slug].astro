---
import "../../../howto/styles.css";
import { DeployLegacyPage } from "../../../howto/components/deploy/deploy-legacy-page.jsx";
import dockerArtifactImageHtml from "../../../howto/components/deploy/legacy-content/docker-artifact-image.html?raw";
import { deployLessons, getDeployLessonNeighbors } from "../../../howto/manuals/deploy/registry.js";

export function getStaticPaths() {
  return deployLessons.map((lesson) => ({
    params: { slug: lesson.slug },
    props: {
      lesson,
      neighbors: getDeployLessonNeighbors(lesson.slug),
    },
  }));
}

const { lesson, neighbors } = Astro.props;

if (!lesson) {
  throw new Error("Missing deploy lesson props");
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{lesson.title} · 部署课程</title>
  </head>
  <body>
    {lesson.slug === "docker-artifact-image" ? (
      <DeployLegacyPage client:load title={`${lesson.title} · 部署课程`} html={dockerArtifactImageHtml} prev={neighbors.prev} next={neighbors.next} />
    ) : (
      <div>Unsupported deploy lesson: {lesson.slug}</div>
    )}
  </body>
</html>
