---
import "../../../styles/global.css";
import howtoStylesSource from "../../../styles/global.css?raw";
import { getCollection } from "astro:content";
import { CourseNavigator } from "../../../howto/components/shared/course-navigator.jsx";
import LessonArticleSection from "../../../howto/components/shared/LessonArticleSection.astro";
import ArticlePreviewCard from "../../../howto/components/shared/ArticlePreviewCard.astro";
import PreviewCodeExample from "../../../howto/components/shared/PreviewCodeExample.astro";
import HtmlCssTabs from "../../../howto/components/shared/HtmlCssTabs.astro";
import FileCodeBlock from "../../../howto/components/shared/FileCodeBlock.astro";
import ManualHeader from "../../../components/ManualHeader.astro";
import { withBasePath, withHowtoManualPath } from "../../../howto/lib/paths.js";
import { createArticleContentExamples } from "../../../howto/manuals/guide/article-content.examples.js";
import { blogManual, guideLessons, toGuideLesson } from "../../../howto/manuals/guide/registry.js";

export async function getStaticPaths() {
  const authoredLessons = (await getCollection("guides")).filter((entry) => !entry.data.hidden).map(toGuideLesson).sort((a, b) => a.order - b.order);
  const lessons = [...guideLessons, ...authoredLessons];
  return lessons.map((lesson, index) => ({
    params: { slug: lesson.slug },
    props: {
      lesson,
      previous: guideLessons[index - 1] ?? null,
      next: guideLessons[index + 1] ?? null,
    },
  }));
}

const { lesson, previous, next } = Astro.props;
const codeLanguage = lesson?.language ?? "html";
const codeLanguageLabel = codeLanguage === "markdown" ? "Markdown" : "HTML";
const lessonHtml = lesson?.html?.replaceAll("lesson-article-hero-copy", "lesson-article-hero-content") ?? "";
const guideIndex = { href: withHowtoManualPath("guide"), label: "全部卡片" };
const guidePrevious = previous ? { href: withHowtoManualPath("guide", previous.slug), label: previous.title } : null;
const guideNext = next ? { href: withHowtoManualPath("guide", next.slug), label: next.title } : null;
const isArticleLesson = lesson?.label?.startsWith("ARTICLE");
const articleHeroMeta = lesson?.slug === "article-content"
  ? ["教程文章 · ARTICLE", "正文结构 · CONTENT", "H2 至 H4"]
  : ["教程文章 · ARTICLE", "文章 Hero · ENTRY", "建立阅读预期"];
const articleExamples = createArticleContentExamples(howtoStylesSource);
const headingHtml = articleExamples.headings.html;
const headingCss = articleExamples.headings.css;
const tocHtml = articleExamples.toc.html;
const tocCss = articleExamples.toc.css;
const navTocHtml = articleExamples.navToc.html;
const navTocCss = articleExamples.navToc.css;
const previewCardHtml = articleExamples.previewCard.html;
const previewCardCss = articleExamples.previewCard.css;
const articleBodyHtml = articleExamples.articleBody.html;
const articleBodyCss = articleExamples.articleBody.css;
const blockquoteHtml = articleExamples.blockquote.html;
const blockquoteCss = articleExamples.blockquote.css;
const codeBlockExample = articleExamples.codeBlock.html;
const codeBlockCss = articleExamples.codeBlock.css;
const basicCodePreview = articleExamples.codeBlock.preview;
const basicCodeHtml = articleExamples.basicPreviewCode.html;
const basicCodeCss = articleExamples.basicPreviewCode.css;
const fileCodeExample = articleExamples.fileCodeBlock.code;
const fileCodeBlockHtml = articleExamples.fileCodeBlock.html;
const fileCodeBlockCss = articleExamples.fileCodeBlock.css;
const previewCodePairHtml = articleExamples.previewCodePair.html;
const previewCodePairCss = articleExamples.previewCodePair.css;

// 本页真实的目录数据：仅 article-content 启用左右两栏目录。
// 页内目录 = 本页正文 section；导航目录 = guideLessons 跨课程，按 label 前缀分组。
const isArticleContentPage = lesson?.slug === "article-content";
const articleTocEntries = isArticleContentPage
  ? [
      "文章标题级别",
      "页内目录",
      "导航目录",
      "预览区",
      "正文",
      "引用块",
      "代码块",
      "预览块 + 代码块",
    ].map((title, index) => ({ title, id: `article-section-${index + 1}` }))
  : [];
const guideNavGroups = (() => {
  const groups = new Map();
  for (const item of guideLessons) {
    const prefix = item.label?.split("·")[0]?.trim() ?? "OTHER";
    if (!groups.has(prefix)) groups.set(prefix, []);
    groups.get(prefix).push({
      slug: item.slug,
      title: item.title,
      href: withHowtoManualPath("guide", item.slug),
      isCurrent: item.slug === lesson?.slug,
    });
  }
  return [...groups.entries()].map(([label, items]) => ({ label, items }));
})();

if (!lesson) {
  throw new Error(`Unknown guide lesson: ${Astro.params.slug}`);
}

function escapeHtml(value) {
  return value.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}

function highlightLine(line, language) {
  if (language === "css") {
    const escaped = escapeHtml(line);
    return escaped
      .replace(/^(\s*)([.#]?[\w-]+)(\s*\{)/, '$1<span class="code-token-tag">$2</span>$3')
      .replace(/(\b[\w-]+)(:)/g, '<span class="code-token-attribute">$1</span><span class="code-token-operator">$2</span>')
      .replace(/(var\(--[\w-]+\)|#[\da-fA-F]{3,8}|\d+(?:\.\d+)?(?:rem|px|vw|%))/g, '<span class="code-token-string">$1</span>');
  }
  return line.split(/(<[^>]*>)/g).map((part) => {
    const tag = part.match(/^(<\/?)([A-Za-z][\w-]*)(.*?)(\/?>)$/);
    if (!tag) return escapeHtml(part);
    const [, opener, name, attributes, closer] = tag;
    const highlightedAttributes = escapeHtml(attributes)
      .replace(/(\s)([\w-]+)(=)/g, '$1<span class="code-token-attribute">$2</span><span class="code-token-operator">$3</span>')
      .replace(/(&quot;.*?&quot;)/g, '<span class="code-token-string">$1</span>');
    return `${escapeHtml(opener)}<span class="code-token-tag">${name}</span>${highlightedAttributes}${escapeHtml(closer)}`;
  }).join("");
}

function prettyCss(css) {
  return css.split("}").map((block) => {
    const [selector, declarations] = block.split("{");
    if (!selector?.trim() || declarations === undefined) return "";
    const properties = declarations.split(";").map((property) => property.trim()).filter(Boolean);
    return `${selector.trim()} {\n${properties.map((property) => `  ${property};`).join("\n")}\n}`;
  }).filter(Boolean).join("\n\n");
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/noto-sans-sc/400.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/noto-sans-sc/700.css" />
    <title>{lesson.title} · {blogManual.title}</title>
    <meta name="description" content={lesson.summary} />
  </head>
  <body class="guide-manual-body">
    <div class="site-shell guide-manual-page">
      <ManualHeader
        variant="manual"
        navItems={[
          { href: withHowtoManualPath("frontend"), label: "前端手册" },
          { href: withHowtoManualPath("deploy"), label: "部署手册" },
          { href: withHowtoManualPath("guide"), label: "指导手册" }
        ]}
        manualHref={withBasePath("howto/")}
        manualLabel="课程"
      />

      <main class:list={["container", "guide-lesson-page", { "guide-component-doc": lesson.slug === "hero", "guide-article-lesson": isArticleLesson, "guide-article-layout": isArticleContentPage }]}>
        <div class="guide-article-content">
        <CourseNavigator previous={guidePrevious} index={guideIndex} next={guideNext} placement="top" label="组件课程导航" />
        {isArticleLesson ? (
          <header class="lesson-article-hero html-reading-hero guide-article-lesson-hero">
            <div class="lesson-shell">
              <div class="lesson-article-hero-meta lesson-article-hero-meta-side">
                <span class="lesson-article-hero-pill lesson-article-hero-pill-fill">{articleHeroMeta[0]}</span>
                <span class="lesson-article-hero-pill">{articleHeroMeta[1]}</span>
                <span class="lesson-article-hero-label">{articleHeroMeta[2]}</span>
              </div>
              <div class="lesson-article-hero-grid">
                <div class="lesson-article-hero-content">
                  <h1 class="page-title"><span class="lesson-article-hero-title-line">{lesson.title}</span></h1>
                  <p class="lesson-article-hero-summary">{lesson.summary}</p>
                </div>
              </div>
            </div>
          </header>
        ) : (
          <section class="hero guide-lesson-hero lesson-shell">
            <div class="hero-grid">
              <div class="hero-copy-block">
                {lesson.slug === "hero" ? <span class="guide-doc-breadcrumb">GUIDE / COMPONENTS</span> : <span class="micro-label">{lesson.label} / GUIDE COMPONENT</span>}
                <h1 class="hero-title-structured">{lesson.title}</h1>
                <p class="hero-subtitle-structured">{lesson.summary}</p>
              </div>
            </div>
          </section>
        )}

        {lesson.slug !== "hero" && lesson.slug !== "article-content" && (
          <section class="section lesson-shell">
            <div class="section-header">
              <div class="section-kicker-wrap"><span class="section-kicker">场景说明</span></div>
              <p class="section-subtitle">{lesson.purpose}</p>
            </div>
          </section>
        )}

        {lesson.slug === "hero" && (
          <section class="section guide-preview-section lesson-shell">
            <div class="section-header">
              <div class="section-kicker-wrap"><span class="section-kicker">示例</span></div>
              <p class="section-subtitle">下面这块使用的正是随后代码中的 HTML 与 class。</p>
            </div>
            <div class="guide-live-preview">
              <section class="hero">
                <div class="hero-grid">
                  <div class="hero-copy-block">
                    <h1 class="hero-title-structured">课程 Hero 标题区</h1>
                    <p class="hero-subtitle-structured">课程开始时，用一个完整的标题区交代主题、学习收益和起步动作。</p>
                    <div class="hero-actions">
                      <a class="button" href="#lesson">开始课程 →</a>
                    </div>
                  </div>
                </div>
              </section>
            </div>
          </section>
        )}

        {lesson.slug === "lesson-nav" && (
          <section class="section guide-preview-section lesson-shell">
            <div class="section-header">
              <div class="section-kicker-wrap"><span class="section-kicker">实际渲染效果</span></div>
              <p class="section-subtitle">这就是课程页顶部与底部使用的共享导航组件。</p>
            </div>
            <CourseNavigator previous={guidePrevious} index={guideIndex} next={guideNext} placement="preview" label="组件课程导航示例" />
          </section>
        )}

        {lesson.slug === "html-reading-hero" && (
          <section class="section guide-preview-section lesson-shell">
            <div class="section-header">
              <div class="section-kicker-wrap"><span class="section-kicker">实际渲染效果</span></div>
              <p class="section-subtitle">用并列标题与纵向元信息，先建立文章的阅读预期。</p>
            </div>
            <header class="lesson-article-hero html-reading-hero">
              <div class="lesson-shell">
                <div class="lesson-article-hero-meta"><span class="lesson-article-hero-pill lesson-article-hero-pill-fill">Markdown 对照 · COMPARE</span><span class="lesson-article-hero-pill">HTML 第一课 · 语法对照</span><span class="lesson-article-hero-label">阅读时长 ≈ 12 分钟</span></div>
                <div class="lesson-article-hero-grid">
                  <div class="lesson-article-hero-content"><h1 class="page-title"><span class="lesson-article-hero-title-line">Markdown</span><span class="lesson-article-hero-title-line">怎么翻成 <span class="lesson-article-hero-title-em">HTML</span></span></h1></div>
                  <div class="lesson-article-hero-side"><div class="lesson-article-hero-row"><span class="lesson-article-hero-key">本页讲什么</span><span class="lesson-article-hero-value">Markdown ↔ HTML</span></div><div class="lesson-article-hero-row"><span class="lesson-article-hero-key">内容形式</span><span class="lesson-article-hero-value">语法对照 + 实时渲染</span></div><div class="lesson-article-hero-row"><span class="lesson-article-hero-key">适合谁</span><span class="lesson-article-hero-value">后端 / 新手 / 会 Markdown 的人</span></div><div class="lesson-article-hero-row"><span class="lesson-article-hero-key">目标</span><span class="lesson-article-hero-value">看见符号就想到标签</span></div></div>
                </div>
              </div>
            </header>
          </section>
        )}

        {lesson.slug === "article-content" && (
          <LessonArticleSection id="article-section-1" title="文章标题级别" className="guide-preview-section">
            <p class="guide-article-body-label">预览</p>
            <ArticlePreviewCard>
              <section>
                <h2>文章二级标题</h2>
                <section>
                  <h3>文章三级标题</h3>
                  <section>
                    <h4>文章四级标题</h4>
                  </section>
                </section>
              </section>
            </ArticlePreviewCard>
            <p class="guide-article-body-label">正文 Markdown 格式</p>
            <figure class="guide-code-figure">
              <pre class="guide-code" tabindex="0" data-language={codeLanguage} data-theme="github-light-default"><button class="guide-code-copy" type="button" data-copy-code aria-label={`复制 ${codeLanguageLabel} 代码`}><span class="sr-only">复制</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg></button><code data-line-numbers data-language={codeLanguage}>{lessonHtml.split("\n").map((line) => <span data-line set:html={highlightLine(line || " ", codeLanguage)}></span>)}</code></pre>
            </figure>
            <p class="guide-article-body-label">HTML + CSS</p>
            <HtmlCssTabs id="article-headings" html={headingHtml} css={headingCss} />
          </LessonArticleSection>
        )}

        {lesson.slug === "article-content" && (
          <LessonArticleSection id="article-section-2" title="页内目录">
            <p class="guide-article-body-label">预览</p>
            <ArticlePreviewCard>
              <nav class="lesson-article-toc" aria-label="文章目录">
                <span class="lesson-article-toc-label">目录</span>
                <ol class="lesson-article-toc-list">
                  <li>
                    <a href="#why">为什么需要多阶段构建</a>
                    <ol class="lesson-article-toc-sub">
                      <li><a href="#problem">单阶段构建的局限</a></li>
                      <li><a href="#idea">分阶段的思路</a></li>
                    </ol>
                  </li>
                  <li>
                    <a href="#how">如何分离构建与运行</a>
                  </li>
                  <li>
                    <a href="#check">发布前检查</a>
                  </li>
                </ol>
              </nav>
            </ArticlePreviewCard>
            <p class="guide-article-body-label">HTML + CSS</p>
            <HtmlCssTabs id="article-toc" html={tocHtml} css={tocCss} />
          </LessonArticleSection>
        )}

        {lesson.slug === "article-content" && (
          <LessonArticleSection id="article-section-3" title="导航目录">
            <p class="guide-article-body-label">预览</p>
            <ArticlePreviewCard>
              <nav class="lesson-article-nav" aria-label="导航目录">
                <span class="lesson-article-nav-title">导航目录</span>
                <ul class="lesson-article-nav-group">
                  <li class="lesson-article-nav-group-label">SECTIONS</li>
                  <li><a class="lesson-article-nav-item is-active" href="#hero">课程 Hero 标题区</a></li>
                  <li><a class="lesson-article-nav-item" href="#heading">课程章节引导区</a></li>
                  <li><a class="lesson-article-nav-item" href="#actions">行动与状态区</a></li>
                </ul>
                <ul class="lesson-article-nav-group">
                  <li class="lesson-article-nav-group-label">COMPONENTS</li>
                  <li><a class="lesson-article-nav-item" href="#card">课程目录入口</a></li>
                  <li><a class="lesson-article-nav-item" href="#faq">检查与答疑区</a></li>
                </ul>
              </nav>
            </ArticlePreviewCard>
            <p class="guide-article-body-label">HTML + CSS</p>
            <HtmlCssTabs id="article-nav-toc" html={navTocHtml} css={navTocCss} />
          </LessonArticleSection>
        )}

        {lesson.slug === "article-content" && (
          <LessonArticleSection id="article-section-4" title="预览区">
            <ArticlePreviewCard>
              <p>这是一块预览区。</p>
            </ArticlePreviewCard>
            <HtmlCssTabs id="preview-card" html={previewCardHtml} css={previewCardCss} />
          </LessonArticleSection>
        )}

        {lesson.slug === "article-content" && (
          <LessonArticleSection id="article-section-5" title="正文">
            <ArticlePreviewCard>
              <p>这是一段正文，用来说明当前章节要解决的问题与读者将获得的结果。</p>
              <p>第二段继续补充关键判断、示例背景或下一步动作，让读者可以顺着内容完成学习。</p>
            </ArticlePreviewCard>
            <HtmlCssTabs id="article-body" html={articleBodyHtml} css={articleBodyCss} />
            <blockquote class="lesson-article-inline-note">
              <p><code>p + p</code> 表示选择紧跟在另一个 <code>p</code> 后面的段落，因此为第二段及后续段落加入间距。</p>
            </blockquote>
          </LessonArticleSection>
        )}

        {lesson.slug === "article-content" && (
          <LessonArticleSection id="article-section-6" title="引用块">
            <p class="guide-article-body-label">正文批注条</p>
            <blockquote class="lesson-article-inline-note">
              <p><code>p + p</code> 表示选择紧跟在另一个 <code>p</code> 后面的段落，因此为第二段及后续段落加入间距。</p>
            </blockquote>
            <p class="guide-article-body-label">高亮纸条</p>
            <aside class="lesson-article-highlight-note">
              <p><code>p + p</code> 为连续段落建立稳定的阅读间距。</p>
            </aside>
            <HtmlCssTabs id="article-quote" html={blockquoteHtml} css={blockquoteCss} />
          </LessonArticleSection>
        )}

        {lesson.slug === "article-content" && (
          <LessonArticleSection id="article-section-7" title="代码块">
            <p class="guide-article-body-label">基础代码块预览</p>
            <ArticlePreviewCard>
              <pre class="guide-code" tabindex="0" data-language="javascript"><code>{basicCodePreview}</code></pre>
            </ArticlePreviewCard>
            <p class="guide-article-body-label">基础代码块：HTML + CSS</p>
            <HtmlCssTabs id="basic-preview-code" html={basicCodeHtml} css={basicCodeCss} />
            <p class="guide-article-body-label">HTML + CSS 组合预览</p>
            <ArticlePreviewCard>
              <HtmlCssTabs id="code-block-preview" html={codeBlockExample} css={codeBlockCss} />
            </ArticlePreviewCard>
            <HtmlCssTabs id="code-block" html={codeBlockExample} css={codeBlockCss} />
            <p class="guide-article-body-label">带文件名的代码块的预览</p>
            <ArticlePreviewCard>
              <FileCodeBlock filename="components.json" code={fileCodeExample} />
            </ArticlePreviewCard>
            <HtmlCssTabs id="file-code-block" html={fileCodeBlockHtml} css={fileCodeBlockCss} />
          </LessonArticleSection>
        )}

        {lesson.slug === "article-content" && (
          <LessonArticleSection id="article-section-8" title="预览块 + 代码块">
            <PreviewCodeExample>
              <ArticlePreviewCard slot="preview">
                <p>这是一块预览区。</p>
              </ArticlePreviewCard>
              <Fragment slot="code">
                <figure class="guide-code-figure">
                  <pre class="guide-code" tabindex="0" data-language="html" data-theme="github-light-default"><button class="guide-code-copy" type="button" data-copy-code aria-label="复制 HTML 代码"><span class="sr-only">复制</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg></button><code data-line-numbers data-language="html">{codeBlockExample.split("\n").map((line) => <span data-line set:html={highlightLine(line || " ", "html")}></span>)}</code></pre>
                </figure>
              </Fragment>
            </PreviewCodeExample>
            <HtmlCssTabs id="preview-code-pair" html={previewCodePairHtml} css={previewCodePairCss} />
          </LessonArticleSection>
        )}

        {lesson.slug !== "article-content" && (
          <section class="section guide-code-section lesson-shell">
            <div class="section-header">
              <div class="section-kicker-wrap"><span class="section-kicker">{codeLanguage === "markdown" ? "Markdown 标题范式" : "HTML 结构与 class"}</span></div>
              <p class="section-subtitle">代码中的标题和说明与当前场景保持一致，展示实际使用的内容结构。</p>
            </div>
          <figure class="guide-code-figure">
            <pre class="guide-code" tabindex="0" data-language={codeLanguage} data-theme="github-light-default"><button class="guide-code-copy" type="button" data-copy-code aria-label={`复制 ${codeLanguageLabel} 代码`}><span class="sr-only">复制</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-1h10"></path></svg></button><code data-line-numbers data-language={codeLanguage}>{lessonHtml.split("\n").map((line) => <span data-line set:html={highlightLine(line || " ", codeLanguage)}></span>)}</code></pre>
          </figure>
          </section>
        )}

        {lesson.slug !== "article-content" && (
          <section class="section guide-code-section guide-css-section lesson-shell">
            <div class="guide-css-heading">
              <h2>CSS 实际样子</h2>
              <p>以下是对应 class 的关键视觉规则，完整定义复用全局手册样式。</p>
            </div>
          <figure class="guide-code-figure">
            <pre class="guide-code" tabindex="0" data-language="css" data-theme="github-light-default"><button class="guide-code-copy" type="button" data-copy-code aria-label="复制 CSS 代码"><span class="sr-only">复制</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg></button><code data-line-numbers data-language="css">{prettyCss(lesson.css).split("\n").map((line) => <span data-line set:html={highlightLine(line || " ", "css")}></span>)}</code></pre>
          </figure>
          </section>
        )}

        <CourseNavigator previous={guidePrevious} index={guideIndex} next={guideNext} placement="bottom" label="组件课程导航" />
        </div>

        {isArticleContentPage && (
          <aside class="guide-article-rail guide-article-nav-rail" aria-label="导航目录">
            <nav class="lesson-article-nav">
              <span class="lesson-article-nav-title">导航目录</span>
              {guideNavGroups.map((group) => (
                <ul class="lesson-article-nav-group">
                  <li class="lesson-article-nav-group-label">{group.label}</li>
                  {group.items.map((item) => (
                    <li>
                      <a class:list={["lesson-article-nav-item", { "is-active": item.isCurrent }]} href={item.href} aria-current={item.isCurrent ? "page" : undefined}>{item.title}</a>
                    </li>
                  ))}
                </ul>
              ))}
            </nav>
          </aside>
        )}

        {isArticleContentPage && (
          <aside class="guide-article-rail guide-article-toc-rail" aria-label="页内目录">
            <nav class="lesson-article-toc" data-article-toc>
              <span class="lesson-article-toc-label">页内目录</span>
              <ol class="lesson-article-toc-list">
                {articleTocEntries.map((entry, index) => (
                  <li>
                    <a href={`#${entry.id}`} data-toc-target={entry.id} class:list={[{ "is-active": index === 0 }]}>{entry.title}</a>
                  </li>
                ))}
              </ol>
            </nav>
          </aside>
        )}

      </main>
    </div>
  </body>
</html>

<script>
  document.querySelectorAll("[data-copy-code]").forEach((button) => {
    button.addEventListener("click", async () => {
      const code = button.closest(".file-code-block")?.querySelector("code") ?? button.parentElement?.querySelector("code");
      if (!code) return;
      await navigator.clipboard.writeText(code.innerText);
      button.setAttribute("data-copied", "true");
      button.setAttribute("aria-label", "已复制");
      window.setTimeout(() => {
        button.removeAttribute("data-copied");
        const label = code.dataset.language === "css" ? "CSS" : code.dataset.language === "json" ? "JSON" : code.dataset.language === "html-css" ? "HTML + CSS" : "HTML";
        button.setAttribute("aria-label", `复制 ${label} 代码`);
      }, 1400);
    });
  });

  document.querySelectorAll("[data-toggle-preview-code]").forEach((button) => {
    button.addEventListener("click", () => {
      const pair = button.closest(".lesson-preview-code-pair");
      if (!pair) return;
      const collapsed = pair.classList.toggle("is-code-collapsed");
      button.setAttribute("aria-expanded", String(!collapsed));
      const label = button.querySelector("span");
      if (label) label.textContent = collapsed ? "展开代码" : "收起代码";
      const icon = button.lastElementChild;
      if (icon) icon.textContent = collapsed ? "↓" : "↑";
    });
  });

  document.querySelectorAll("[data-code-tabs]").forEach((tabs) => {
    const buttons = [...tabs.querySelectorAll("[data-code-tab]")];
    const panels = [...tabs.querySelectorAll("[data-code-panel]")];
    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const language = button.dataset.codeTab;
        buttons.forEach((item) => item.setAttribute("aria-selected", String(item === button)));
        panels.forEach((panel) => { panel.hidden = panel.dataset.codePanel !== language; });
      });
    });
  });

  document.querySelectorAll("[data-copy-html-css]").forEach((button) => {
    button.addEventListener("click", async () => {
      const tabs = button.closest("[data-code-tabs]");
      const html = tabs?.querySelector('[data-code-panel="html"] code')?.innerText ?? "";
      const css = tabs?.querySelector('[data-code-panel="css"] code')?.innerText ?? "";
      await navigator.clipboard.writeText(`<!-- HTML -->\n${html}\n\n/* CSS */\n${css}`);
      button.setAttribute("data-copied", "true");
      button.textContent = "已复制 HTML + CSS";
      window.setTimeout(() => {
        button.removeAttribute("data-copied");
        button.textContent = "复制 HTML + CSS";
      }, 1400);
    });
  });

  // 页内目录滚动高亮：观察正文 section，把当前可见章节在右栏 TOC 上标为 is-active。
  const articleToc = document.querySelector("[data-article-toc]");
  if (articleToc && "IntersectionObserver" in window) {
    const links = Array.from(articleToc.querySelectorAll("a[data-toc-target]"));
    const sections = links
      .map((link) => document.getElementById(link.dataset.tocTarget))
      .filter(Boolean);
    if (sections.length) {
      const ratios = new Map();
      const setActive = () => {
        let activeId = sections[0].id;
        let max = 0;
        for (const section of sections) {
          const ratio = ratios.get(section.id) ?? 0;
          if (ratio > max) {
            max = ratio;
            activeId = section.id;
          }
        }
        links.forEach((link) => {
          link.classList.toggle("is-active", link.dataset.tocTarget === activeId);
        });
      };
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            ratios.set(entry.target.id, entry.isIntersecting ? entry.intersectionRatio : 0);
          }
          setActive();
        },
        { rootMargin: "-96px 0px -55% 0px", threshold: [0, 0.1, 0.25, 0.5, 1] }
      );
      sections.forEach((section) => observer.observe(section));
    }
  }
</script>

