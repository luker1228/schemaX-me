---
import "../../styles/global.css";
import ManualHeader from "../../components/ManualHeader.astro";
import { withBasePath, withHowtoManualPath } from "../../howto/lib/paths.js";
import { deployManual } from "../../howto/manuals/deploy/registry.js";
import { blogManual } from "../../howto/manuals/guide/registry.js";

const withBase = withBasePath;

const manuals = [
  {
    code: "FM-01",
    stamp: "已解密",
    stampImage: withBase("images/brand/stamps/stamp-cracked.svg"),
    title: "前端课程",
    copy: "写给后端、设计和零基础同学的前端速通。HTML 结构、CSS 样式、JavaScript、React 组件与布局，边改边看。",
    meta: "HTML · CSS · JS · React · 布局",
    href: withHowtoManualPath("frontend"),
    audience: "设计 / 产品 / 运营 / 后端",
    focus: "把页面拆清楚，把组件说明白，把 AI 改前端这件事做对。",
    outcome: "看懂页面结构、样式层次、状态变化和组件边界。"
  },
  {
    code: "FM-02",
    stamp: "已解密",
    stampImage: withBase("images/brand/stamps/stamp-cracked.svg"),
    title: deployManual.title,
    copy: deployManual.description,
    meta: "Docker · 镜像 · 配置 · K8s",
    href: withHowtoManualPath("deploy"),
    audience: "后端 / 全栈 / 独立开发者",
    focus: "把产物、镜像、环境和运行边界理清楚，避免上线时才补概念。",
    outcome: "判断什么该打包、什么该外置、什么该留给运行环境。"
  },
  {
    code: blogManual.code,
    stamp: "已解密",
    stampImage: withBase("images/brand/stamps/stamp-cracked.svg"),
    title: blogManual.title,
    copy: blogManual.description,
    meta: blogManual.meta,
    href: withHowtoManualPath("guide"),
    audience: blogManual.audience,
    focus: blogManual.focus,
    outcome: blogManual.outcome
  }
];


---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>课程 · schemaX 绝密计划</title>
    <meta name="description" content="schemaX 课程：前端、部署等可独立完成的小战场索引。" />
  </head>
  <body>
    <div class="site-shell manual-hub-shell">
      <ManualHeader
        variant="manual"
        navItems={[
          { href: withHowtoManualPath("frontend"), label: "前端手册" },
          { href: withHowtoManualPath("deploy"), label: "部署手册" },
          { href: withHowtoManualPath("guide"), label: "指导手册" }
        ]}
        manualHref={withBase("howto/")}
        manualLabel="课程"
      />

      <main class="container manual-hub-main">
        <section class="hero manual-overview-hero">
          <div class="hero-grid">
            <div class="hero-copy-block">
              <div class="hero-title-wrap">
                <h1 class="hero-title-structured manual-overview-title">
                  <span class="hero-title-row1">课程</span>
                  <span class="accent-text">总览入口</span>
                </h1>
              </div>
              <div class="hero-search-card bare">
                <div class="hero-tags">
                  <span class="tag">课程总览</span>
                  <span class="tag">按问题选路线</span>
                  <span class="tag">统一结构</span>
                  <span class="tag">独立阅读</span>
                </div>
              </div>
            </div>

            <aside class="hero-note manual-overview-note">
              <span class="micro-label">你会在这里拿到什么</span>
              <p class="hero-note-copy">
      这是你使用AI快速进行 XXX 的必要基础知识。 帮助你更好的写出正确的提示词。
                提升你对AI的表达能力
              </p>
            </aside>
          </div>
        </section>

        <section class="section manual-overview-section" aria-labelledby="overview-summary">
          <div class="section-header">
            <div>
              <span class="micro-label">OVERVIEW</span>
              <h2 class="section-title" id="overview-summary">先看地图，再选手册</h2>
              <p class="section-subtitle">每本手册解决的问题不同，阅读方式也不同。</p>
            </div>
          </div>

          <div class="manual-overview-grid">
            <article class="manual-overview-card">
              <span class="micro-label">当前收录</span>
              <h3>两本手册，两类问题</h3>
              <p>前端手册解决“页面怎么表达”，部署手册解决“应用怎么上线”。</p>
            </article>
            <article class="manual-overview-card">
              <span class="micro-label">适合谁</span>
              <h3>不是同一批读者</h3>
              <p>前端更适合设计、产品、运营和后端；部署更适合后端、全栈和独立开发者。</p>
            </article>
            <article class="manual-overview-card">
              <span class="micro-label">阅读方式</span>
              <h3>按卡点进入</h3>
              <p>卡在页面表达就进前端，卡在产物、镜像、环境和上线边界就进部署。</p>
            </article>
          </div>
        </section>

        <section class="section manual-overview-section" aria-labelledby="manual-routes">
          <div class="section-header">
            <div>
              <span class="micro-label">MANUAL ROUTES</span>
              <h2 class="section-title" id="manual-routes">两条路线</h2>
              <p class="section-subtitle">选一条先走，不需要同时啃完。</p>
            </div>
          </div>

          <div class="manual-hub-grid" aria-label="手册目录">
            {manuals.map((manual) => (
              <a
                class="manual-hub-card"
                href={manual.href}
              >
                <div class="manual-hub-card-head">
                  <span class="manual-hub-code">{manual.code}</span>
                  <span class="manual-hub-meta">{manual.meta}</span>
                </div>
                <div class="manual-hub-card-body">
                  <h2>{manual.title}</h2>
                  <p>{manual.copy}</p>
                </div>
                <div class="manual-hub-card-detail">
                  <div>
                    <span class="micro-label">适合人群</span>
                    <p>{manual.audience}</p>
                  </div>
                  <div>
                    <span class="micro-label">核心焦点</span>
                    <p>{manual.focus}</p>
                  </div>
                  <div>
                    <span class="micro-label">读完之后</span>
                    <p>{manual.outcome}</p>
                  </div>
                </div>
                <div class="manual-hub-card-foot">
                  <img
                    class="manual-hub-stamp"
                    src={manual.stampImage}
                    alt={manual.stamp}
                    width="132"
                    height="58"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="manual-hub-enter">进入手册 →</span>
                </div>
              </a>
            ))}
          </div>
        </section>

        <section class="section manual-overview-section manual-overview-end" aria-labelledby="pick-manual">
          <div class="section-header">
            <div>
              <span class="micro-label">QUICK PICK</span>
              <h2 class="section-title" id="pick-manual">怎么选更快</h2>
            </div>
          </div>

          <div class="manual-pick-grid">
            <article class="manual-pick-card">
              <span class="micro-label">如果你在想</span>
              <h3>“我不会描述页面，也不会拆组件”</h3>
              <p>先去前端手册。先把结构、样式、状态和组件边界建立起来，再谈工程细节。</p>
              <a href={withHowtoManualPath("frontend")}>进入前端手册 →</a>
            </article>
            <article class="manual-pick-card">
              <span class="micro-label">如果你在想</span>
              <h3>“我能跑起来，但为什么一部署就坏”</h3>
              <p>先去部署手册。先把产物、镜像、配置和运行环境之间的边界理清楚。</p>
              <a href={withHowtoManualPath("deploy")}>进入部署手册 →</a>
            </article>
          </div>
        </section>
      </main>
    </div>

  </body>
</html>

<style>
  .manual-hub-shell {
    --bg: #fff7e8;
    --surface: #fffdf7;
    --surface-2: #fff2ce;
    --fg: #241d13;
    --ink: #241d13;
    --muted: #6b5c42;
    --border: #241d13;
    --accent: #ffd43b;
    --accent-strong: #a85f00;
    --shadow: 4px 4px 0 rgba(36, 29, 19, 0.24);
    position: relative;
    background:
      radial-gradient(circle at top right, rgba(255, 212, 59, 0.18), transparent 24%),
      linear-gradient(rgba(36, 29, 19, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(36, 29, 19, 0.055) 1px, transparent 1px),
      var(--bg);
    background-size: auto, 24px 24px, 24px 24px, auto;
  }

  .manual-hub-shell .manual-topbar-header {
    background: rgba(255, 253, 247, 0.94);
    border-bottom: 1px solid var(--border);
  }

  .manual-hub-shell .manual-site-nav a[aria-current="page"],
  .manual-hub-shell .header-action-manual[aria-current="page"] {
    background: var(--accent);
    color: var(--ink);
    border: 1px solid var(--border);
    box-shadow: 4px 4px 0 var(--border);
  }

  .manual-hub-main {
    padding-top: 2rem;
    padding-bottom: 4rem;
  }

  .manual-overview-hero {
    padding-top: 1.2rem;
  }

  .manual-overview-summary {
    max-width: 24ch;
  }

  .manual-overview-actions {
    justify-content: flex-start;
    gap: 0.8rem;
  }

  .manual-overview-secondary {
    background: var(--surface-2);
  }

  .manual-overview-note {
    padding-top: 1.6rem;
    text-align: left;
  }

  .manual-overview-note .hero-note-copy {
    margin-left: 0;
    margin-right: 0;
  }

  .manual-hub-note,
  .manual-hub-card {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.38), transparent 28%),
      var(--surface);
    border: 2px solid var(--border);
    box-shadow: var(--shadow);
  }

  .manual-overview-section {
    padding-top: 2.4rem;
  }

  .manual-overview-grid,
  .manual-pick-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .manual-pick-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .manual-overview-card,
  .manual-pick-card {
    padding: 1.15rem 1.2rem 1.25rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.38), transparent 28%),
      var(--surface);
    border: 1.5px solid var(--fg);
  }

  .manual-pick-card {
    box-shadow: var(--shadow);
  }

  .manual-overview-card h3,
  .manual-pick-card h3 {
    margin: 0.45rem 0 0;
    font-size: 1.2rem;
    line-height: 1.15;
  }

  .manual-overview-card p,
  .manual-pick-card p {
    margin: 0.65rem 0 0;
    color: var(--muted);
    font-size: 0.98rem;
  }

  .manual-hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.2rem;
  }

  .manual-hub-card {
    display: grid;
    gap: 1rem;
    min-height: 420px;
    padding: 1.15rem;
    transition: transform 150ms ease, box-shadow 150ms ease, background 150ms ease;
  }

  .manual-hub-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, transparent 0 72%, rgba(0, 0, 0, 0.05) 72% 74%, transparent 74%),
      repeating-linear-gradient(90deg, rgba(36, 29, 19, 0.06) 0 1px, transparent 1px 18px);
    opacity: 0.45;
    pointer-events: none;
  }

  .manual-hub-card:hover,
  .manual-hub-card:focus-visible {
    transform: translateY(-4px);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.45), transparent 28%),
      var(--surface-2);
    box-shadow: 7px 7px 0 var(--border);
  }

  .manual-hub-card > * {
    position: relative;
    z-index: 1;
  }

  .manual-hub-card-head,
  .manual-hub-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .manual-hub-code,
  .manual-hub-meta,
  .manual-hub-enter {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .manual-hub-code {
    display: inline-flex;
    padding: 0.2rem 0.45rem;
    background: var(--ground-yellow);
    border: 1px solid var(--border);
  }

  .manual-hub-meta {
    color: var(--muted);
    text-align: right;
  }

  .manual-hub-card-body h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    line-height: 0.96;
    text-transform: uppercase;
  }

  .manual-hub-card-body p {
    margin: 0.8rem 0 0;
    color: var(--muted);
    font-size: 0.98rem;
  }

  .manual-hub-card-detail {
    display: grid;
    gap: 0.85rem;
    padding-top: 0.15rem;
    border-top: 1px solid rgba(36, 29, 19, 0.18);
  }

  .manual-hub-card-detail p {
    margin: 0.28rem 0 0;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .manual-hub-stamp {
    width: 132px;
    height: auto;
    opacity: 0.82;
    mix-blend-mode: multiply;
  }

  .manual-hub-enter {
    color: var(--accent);
  }

  .manual-pick-card a {
    display: inline-flex;
    margin-top: 1rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .manual-overview-grid,
    .manual-pick-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .manual-hub-main {
      padding-top: 1.2rem;
    }

    .manual-overview-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .manual-hub-card-head,
    .manual-hub-card-foot {
      flex-direction: column;
      align-items: flex-start;
    }

    .manual-hub-meta {
      text-align: left;
    }
  }
</style>
