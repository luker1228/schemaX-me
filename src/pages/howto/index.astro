---
import BaseLayout from "../../layouts/BaseLayout.astro";

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const withBase = (p: string) => `${baseUrl}${p.replace(/^\//, "")}`;

// 战术手册索引。新增手册只需往这里加一项；href 为空字符串的渲染为不可点占位卡。
const manuals = [
  {
    code: "FM-01",
    status: "已上线",
    tone: "yellow",
    title: "前端战术手册",
    copy: "写给后端、设计和零基础同学的前端速通——HTML 结构、CSS 样式、JavaScript、React 组件与布局,边改边看。",
    meta: "HTML · CSS · JS · React · 布局 →",
    href: withBase("howto/frontend/")
  },
  {
    code: "FM-02",
    status: "整理中",
    tone: "cyan",
    title: "部署战术手册",
    copy: "把应用安全地推上线:环境变量、CI/CD、容器、域名与运维排错。",
    meta: "待部署 · 内容整理中",
    href: ""
  }
];
---

<BaseLayout
  title="战术手册 · schemaX 绝密计划"
  description="schemaX 战术手册:前端、部署等可独立完成的小战场索引。"
>
  <section class="shell-wide dossier" style="min-height: 72vh;">
    <div class="dossier-atmosphere" aria-hidden="true"></div>

    <div class="dossier-wrap" style="padding-top: 1.5rem;">
      {/* 顶部状态条 */}
      <div class="dossier-topbar">
        <span class="l"
          >luke@human-llm<span style="color:var(--text-soft)">:~/howto</span>$ ls
          ./manuals<span class="cur"></span></span
        >
        <span class="mid">FIELD MANUALS</span>
        <span class="r">
          <span class="dossier-pill rec"><span class="dossier-dot"></span>ACTIVE</span>
          <span class="dossier-pill sec">绝密</span>
        </span>
      </div>

      <div class="dossier-section">
        {/* 章节头 */}
        <div class="dossier-section-head">
          <div>
            <span class="dossier-kicker">// 战术手册 · FIELD MANUALS</span>
            <h2>战术手册</h2>
          </div>
          <p>每一册都是一个可独立完成的小战场——从前端到部署,陆续上线。挑一本进入。</p>
        </div>

        {/* 手册卡片网格(沿用首页「内容入口」的 .dossier-asset) */}
        <div class="dossier-assets">
          {manuals.map((m) =>
            m.href ? (
              <a class={`dossier-asset acc-${m.tone}`} href={m.href}>
                <span class="dossier-corner tl"></span>
                <span class="dossier-corner tr"></span>
                <span class="dossier-corner bl"></span>
                <span class="dossier-corner br"></span>
                <div class="ah">
                  <span class="aid">{m.code}</span>
                  <span class="cls">● {m.status}</span>
                </div>
                <h3>{m.title}</h3>
                <p>{m.copy}</p>
                <span class="meta">{m.meta}</span>
              </a>
            ) : (
              <div class={`dossier-asset acc-${m.tone}`} aria-disabled="true">
                <span class="dossier-corner tl"></span>
                <span class="dossier-corner tr"></span>
                <span class="dossier-corner bl"></span>
                <span class="dossier-corner br"></span>
                <div class="ah">
                  <span class="aid">{m.code}</span>
                  <span class="cls">● {m.status}</span>
                </div>
                <h3>{m.title}</h3>
                <p>{m.copy}</p>
                <span class="meta">{m.meta}</span>
              </div>
            )
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
