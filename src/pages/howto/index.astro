---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBasePath } from "../../howto/lib/paths.js";
import { deployManual } from "../../howto/manuals/deploy/registry.js";

const withBase = withBasePath;

// 战术手册索引。新增手册只需往这里加一项；href 为空字符串的渲染为不可点占位卡。
const manuals = [
  {
    code: "FM-01",
    stamp: "已解密",
    stampImage: withBase("images/brand/stamps/stamp-cracked.svg"),
    title: "前端战术手册",
    copy: "写给后端、设计和零基础同学的前端速通——HTML 结构、CSS 样式、JavaScript、React 组件与布局,边改边看。",
    meta: "HTML · CSS · JS · React · 布局 →",
    href: withBase("howto/frontend/")
  },
  {
    code: "FM-02",
    stamp: "已解密",
    stampImage: withBase("images/brand/stamps/stamp-cracked.svg"),
    title: deployManual.title,
    copy: deployManual.description,
    meta: "Docker · 镜像 · 配置 · K8s →",
    href: withBase("howto/deploy/")
  }
];

const getManualPath = (href: string) => {
  const normalizedBase = (import.meta.env.BASE_URL.replace(/\/?$/, "/")).replace(/\/$/, "");
  const normalizedHref = href.startsWith(normalizedBase) ? href.slice(normalizedBase.length) : href;
  return normalizedHref.replace(/^\/+|\/+$/g, "");
};
---

<BaseLayout
  title="战术手册 · schemaX 绝密计划"
  description="schemaX 战术手册:前端、部署等可独立完成的小战场索引。"
>
  <section class="shell-wide dossier" style="min-height: 72vh;">
    <div class="dossier-atmosphere" aria-hidden="true"></div>
    <img class="hub-bgx" src={withBase("images/brand/bg-x.svg")} alt="" aria-hidden="true" />

    <div class="dossier-wrap" style="padding-top: 1.5rem;">
      {/* 顶部状态条 */}
      <div class="dossier-topbar">
        <span class="l"
          >luke@human-llm<span style="color:var(--text-soft)">:~/howto</span>$ ls
          ./manuals<span class="cur"></span></span
        >
        <span class="mid">FIELD MANUALS</span>
        <span class="r">
          <span class="dossier-pill rec"><span class="dossier-dot"></span>ACTIVE</span>
          <span class="dossier-pill sec">绝密</span>
        </span>
      </div>

      <div class="hub-emblem">
        <img src={withBase("images/brand/emblem-field-manual.svg")} alt="战术手册徽记" width="120" height="120" />
      </div>

      <div class="dossier-section">
        {/* 章节头 */}
        <div class="dossier-section-head">
          <div>
            <span class="dossier-kicker">// 战术手册 · FIELD MANUALS</span>
            <h2>战术手册</h2>
          </div>
        </div>

        {/* 手册卡片网格 —— Bone 牛皮纸档案夹(暗 hub 上的浅色手册,预告目的地) */}
        <div class="dossier-assets">
          {manuals.map((m) =>
            m.href ? (
              <a class="dossier-asset manual-card" href={m.href} data-manual-launch data-manual-title={m.title} data-manual-path={getManualPath(m.href)} data-manual-stamp={m.stampImage}>
                <img class="manual-status-stamp" src={m.stampImage} alt={m.stamp} width="132" height="58" loading="lazy" decoding="async" />
                <h3>{m.title}</h3>
              </a>
            ) : (
              <div class="dossier-asset manual-card" aria-disabled="true">
                <img class="manual-status-stamp" src={m.stampImage} alt={m.stamp} width="132" height="58" loading="lazy" decoding="async" />
                <h3>{m.title}</h3>
              </div>
            )
          )}
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var links = document.querySelectorAll("[data-manual-launch]");
      if (!links.length) return;

      for (var i = 0; i < links.length; i++) {
        links[i].addEventListener("click", function (event) {
          var href = this.getAttribute("href");
          var manualTitle = this.getAttribute("data-manual-title");
          var manualPath = this.getAttribute("data-manual-path");
          var manualStamp = this.getAttribute("data-manual-stamp");
          if (!href || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0) return;
          try {
            sessionStorage.setItem(
              "howto-manual-transition",
              JSON.stringify({
                href: href,
                title: manualTitle || "",
                path: manualPath || "",
                stamp: manualStamp || "",
                expiresAt: Date.now() + 12000
              })
            );
          } catch (e) {}
        });
      }
    })();
  </script>
</BaseLayout>

<style>
  /* 手册卡 = Bone 牛皮纸档案夹(钉在暗 dossier hub 上,浅色预告即将进入的浅色手册) */
  .dossier-assets {
    grid-template-columns: repeat(auto-fit, minmax(220px, 320px));
    align-items: start;
    padding-bottom: 3rem;
  }
  .manual-card {
    position: relative;
    isolation: isolate;
    width: min(100%, 320px);
    min-height: 205px;
    margin-top: 1.15rem;
    padding: 0 !important;
    align-content: start !important;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.18), transparent 38%),
      #eadfbd !important;
    border-color: #241d13 !important;
    border-radius: 4px 4px 2px 2px;
    color: #241d13 !important;
    box-shadow: 6px 6px 0 #c8501e !important;
    overflow: visible !important;
  }
  .manual-card::before {
    content: "";
    position: absolute;
    left: -1px;
    top: -1.15rem;
    width: min(12rem, 68%);
    height: 1.35rem;
    background: #d8c89d;
    border: 1px solid #241d13;
    border-bottom: 0;
    border-radius: 4px 10px 0 0;
    clip-path: polygon(0 0, 82% 0, 100% 100%, 0 100%);
    z-index: -1;
  }
  .manual-card:hover {
    transform: translateY(-3px) rotate(-0.45deg);
    box-shadow: 8px 8px 0 #c8501e !important;
  }
  .manual-card > * {
    position: relative;
    z-index: 1;
  }
  .manual-card h3 {
    position: absolute;
    top: calc(100% + 0.9rem);
    left: 0;
    display: block;
    width: 100%;
    max-width: 100%;
    margin: 0 !important;
    padding: 0 !important;
    background: transparent;
    border: 0;
    color: #e7f3ea !important;
    font-family: var(--font-mono) !important;
    font-size: clamp(0.78rem, 2.8vw, 0.92rem) !important;
    line-height: 1.25 !important;
    text-align: center;
    text-transform: none !important;
    letter-spacing: 0.04em;
    white-space: nowrap;
    overflow: visible;
  }
  .manual-status-stamp {
    position: absolute;
    top: 4.2rem;
    left: 50%;
    width: min(210px, 68%);
    height: auto;
    display: block;
    transform: translateX(-50%) rotate(-7deg);
    opacity: 0.86;
    pointer-events: none;
    user-select: none;
    mix-blend-mode: multiply;
  }
  /* hub 背景 X 母题(淡)+ 战术手册徽记 */
  .hub-bgx {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.16;
    z-index: 0;
    pointer-events: none;
  }
  .hub-emblem {
    position: relative;
    text-align: center;
    margin: 1.4rem 0 0.2rem;
  }
  .hub-emblem img {
    width: 120px;
    height: 120px;
    display: inline-block;
  }
</style>
