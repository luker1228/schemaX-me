---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, getPostsBySeries } from "../lib/content";

const seriesName = "ModelCraft";
const posts = await getPostsBySeries(seriesName);
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<BaseLayout
  title="ModelCraft | Luke's AI Hub"
  description="ModelCraft 项目与系列文章入口页，聚合项目介绍、GitHub 链接与系列目录。"
>
  <section class="shell-wide brutal-hero series-hero">
    <div class="brutal-hero-copy">
      <span class="brutal-kicker">项目 / 系列入口</span>
      <h1 class="brutal-title">MODELCRAFT</h1>
      <p class="brutal-copy">
        一个围绕数据模型引擎、协议自解释、Schema 约束和 Runtime 设计展开的长期项目。这里既是项目入口，也是系列文章总目录。
      </p>
      <div class="series-banner-links series-hero-links">
        <a class="series-link primary" href="https://github.com/luker1228/modelcraft" target="_blank" rel="noreferrer">打开 GitHub 仓库</a>
        <a class="series-link secondary" href="#series-index">查看系列目录</a>
      </div>
      <div class="brutal-metrics" aria-label="ModelCraft series metrics">
        <div class="metric-box">
          <span class="metric-label">系列文章</span>
          <strong>{posts.length}</strong>
        </div>
        <div class="metric-box">
          <span class="metric-label">核心主题</span>
          <strong>Schema / Runtime</strong>
        </div>
      </div>
    </div>

    <a class="lead-feature series-feature" href="https://github.com/luker1228/modelcraft" target="_blank" rel="noreferrer">
      <div class="series-feature-top">
        <p class="lead-feature-label">项目简介</p>
        <svg class="series-feature-github" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="currentColor"
            d="M12 .5C5.65.5.5 5.66.5 12.02c0 5.09 3.29 9.41 7.86 10.94.58.11.79-.25.79-.56 0-.28-.01-1.2-.02-2.18-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.78 1.2 1.78 1.2 1.03 1.77 2.71 1.26 3.37.97.11-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.71 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.47.11-3.06 0 0 .96-.31 3.15 1.18a10.9 10.9 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.59.23 2.77.11 3.06.74.8 1.18 1.83 1.18 3.09 0 4.44-2.69 5.42-5.26 5.7.41.36.78 1.08.78 2.18 0 1.58-.01 2.86-.01 3.25 0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12C23.5 5.66 18.35.5 12 .5Z"
          />
        </svg>
      </div>
      <h2>做一个能解释自己的模型引擎。</h2>
      <p class="lead-feature-copy">
        核心问题不是“再做一个工具”，而是让数据模型、查询能力和权限边界变成一套对开发者和 AI 都可读的协议。
      </p>
    </a>
  </section>

  <section class="shell section brutal-section" id="series-index">
    <div class="brutal-section-head">
      <h2>Series Index</h2>
    </div>

    <div class="recent-list">
      {posts.map((post) => (
        <a class="recent-item" href={`${baseUrl}posts/${post.slug}/`}>
          <span class="recent-date">{formatDate(post.pubDate)}</span>
          <div class="recent-body">
            <strong>{post.title}</strong>
            <p>{post.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
