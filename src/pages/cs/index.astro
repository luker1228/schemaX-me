---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCategoryDescription, getCategoryLabel, getPostsByCategory } from "../../lib/content";

const category = "cs";
const posts = await getPostsByCategory(category);
---

<BaseLayout title="CS | Luke's AI Hub" description={getCategoryDescription(category)}>
  <section class="shell article-shell">
    <div class="section-head">
      <h2>{getCategoryLabel(category)}</h2>
      <p>{getCategoryDescription(category)}</p>
    </div>
    <div class="post-grid">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
