---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, getAllPosts, getCategoryLabel } from "../lib/content";

const posts = await getAllPosts();
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<BaseLayout title="Archive | Luke's AI Hub" description="全部已发布文章的时间归档。">
  <section class="shell article-shell">
    <div class="section-head">
      <h2>Archive</h2>
      <p>{posts.length} 篇已发布文章。</p>
    </div>
    <div class="archive-list">
      {posts.map((post) => (
        <a class="archive-item" href={`${baseUrl}posts/${post.slug}/`}>
          <span class="meta">{formatDate(post.pubDate)}</span>
          <div>
            <strong>{post.title}</strong>
            <p>{getCategoryLabel(post.category)}{post.description ? ` · ${post.description}` : ""}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
