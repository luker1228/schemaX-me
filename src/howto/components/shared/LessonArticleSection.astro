---
interface Props {
  title: string;
  className?: string;
  id?: string;
}

const { title, className, id } = Astro.props;
---

<section id={id} class:list={["section", "lesson-shell", "lesson-article-section", className]}>
  <h2 class="lesson-article-section-title">{title}</h2>
  <slot />
</section>
