      "isDeleted": false,
      "boundElements": null,
      "updated": 1706659200000,
      "link": null,
      "locked": false,
      "text": "结论：不是选“最先进”，而是选\n“最贴合 dynamic GraphQL runtime 的自由度”",
      "fontSize": 24,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle"
    }
